---
import BlogLayout from '../../layouts/BlogLayout.astro'

const team = [
  {
    id:     'ana-martins',
    name:   'Ana Beatriz Martins',
    title:  'Especialista em Ciência do Sono e Nutrição Funcional',
    emoji:  '🌙',
    color:  '#1DB8E8',
    areas:  ['Sono & Insônia', 'Melatonina', 'Ritmo Circadiano', 'Nutrição Funcional'],
    bio:    'Graduada em Ciências da Saúde com pós-graduação em Neurofisiologia do Sono pela USP. Pesquisadora de higiene do sono e intervenções nutricionais para distúrbios do sono há mais de 8 anos. Responsável por revisar os artigos de sono, insônia e ritmo circadiano do blog Zen Caps.',
    articles: ['sono', 'insônia', 'melatonina', 'ritmo circadiano'],
  },
  {
    id:     'rafael-costa',
    name:   'Rafael Costa',
    title:  'Especialista em Saúde Mental e Neurociências',
    emoji:  '🧘',
    color:  '#5B6FDE',
    areas:  ['Ansiedade', 'Estresse', 'Saúde Mental', 'Neurociências'],
    bio:    'Graduado em Psicologia com especialização em Neurociências pela PUC-SP e formação em Manejo do Estresse pelo Instituto de Neurologia de Curitiba. Atua na pesquisa de intervenções não-farmacológicas para ansiedade, burnout e transtornos relacionados ao estresse. Revisor dos artigos de ansiedade e saúde mental.',
    articles: ['ansiedade', 'estresse', 'cortisol', 'respiração'],
  },
  {
    id:     'juliana-ferreira',
    name:   'Juliana Ferreira',
    title:  'Farmacêutica e Pesquisadora em Suplementação Natural',
    emoji:  '🔬',
    color:  '#1DB8E8',
    areas:  ['Farmacologia', 'Fitoterapia', 'Suplementação', 'Biodisponibilidade'],
    bio:    'Farmacêutica graduada pela UNIFESP com mestrado em Fitoterapia e Farmacologia de Suplementos. Especializada em biodisponibilidade de nutrientes, segurança de suplementação natural e interações medicamentosas. Responsável pela revisão científica dos artigos sobre ingredientes, melatonina, triptofano, magnésio e vitamina B6.',
    articles: ['melatonina', 'triptofano', 'magnésio', 'vitamina B6', 'suplementos'],
  },
  {
    id:     'marcos-oliveira',
    name:   'Marcos Oliveira',
    title:  'Especialista em Medicina do Estilo de Vida',
    emoji:  '✨',
    color:  '#C9A84C',
    areas:  ['Hábitos Saudáveis', 'Medicina do Estilo de Vida', 'Crono-nutrição', 'Bem-estar'],
    bio:    'Especialista em Medicina do Estilo de Vida com foco em ritmo circadiano, higiene do sono e hábitos saudáveis baseados em evidências científicas. Formação em Educação Física e pós-graduação em Crono-nutrição pela FMUSP. Revisor dos artigos sobre hábitos, rotina noturna, exercício e alimentação.',
    articles: ['hábitos', 'rotina', 'exercício', 'alimentação', 'sono'],
  },
]

const personSchemas = team.map(member => ({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `https://zencaps.com.br/blog/sobre#${member.id}`,
  name: member.name,
  jobTitle: member.title,
  url: `https://zencaps.com.br/blog/sobre#${member.id}`,
  worksFor: {
    '@type': 'Organization',
    name: 'Zen Caps',
    url: 'https://zencaps.com.br',
  },
  knowsAbout: member.articles,
  description: member.bio,
}))
---

<BlogLayout
  title="Equipe Editorial — Zen Caps Blog"
  description="Conheça os especialistas que produzem e revisam o conteúdo do Zen Caps Blog: ciência do sono, saúde mental, farmacologia e medicina do estilo de vida."
  canonical="https://zencaps.com.br/blog/sobre/"
>

  <!-- Schema.org: Person para cada membro da equipe -->
  {personSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <div style="background: #F4F8FC; min-height: 80vh;">

    <!-- Hero -->
    <section style="background: linear-gradient(135deg, #0D1B3E 0%, #172851 100%); padding: 5rem 1.5rem 4rem;">
      <div style="max-width: 720px; margin: 0 auto; text-align: center;">
        <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: #1DB8E8; margin-bottom: 1rem;">
          Transparência editorial
        </p>
        <h1 style="font-family: 'Sora', system-ui, sans-serif; font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 900; color: #ffffff; line-height: 1.15; margin-bottom: 1.25rem;">
          Quem escreve e revisa<br />o conteúdo do blog
        </h1>
        <p style="font-size: 1.05rem; color: rgba(255,255,255,0.65); line-height: 1.7; max-width: 560px; margin: 0 auto;">
          Todo artigo do Zen Caps Blog é produzido com base em evidências científicas e revisado por especialistas com formação nas áreas abordadas.
        </p>
      </div>
    </section>

    <!-- Processo editorial -->
    <section style="background: #FFFFFF; border-bottom: 1px solid #e8eef6; padding: 3rem 1.5rem;">
      <div style="max-width: 720px; margin: 0 auto;">
        <h2 style="font-family: 'Sora', system-ui, sans-serif; font-size: 1.5rem; font-weight: 800; color: #0D1B3E; margin-bottom: 2rem; text-align: center;">
          Nosso processo editorial
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
          {[
            { step: '01', icon: '🔍', title: 'Pesquisa científica', desc: 'Cada artigo é baseado em estudos publicados em periódicos científicos indexados (PubMed, SciELO).' },
            { step: '02', icon: '✍️', title: 'Redação especializada', desc: 'A equipe editorial transforma evidências complexas em conteúdo acessível e preciso.' },
            { step: '03', icon: '🔬', title: 'Revisão por especialista', desc: 'Cada artigo é revisado por um especialista da área correspondente antes de ser publicado.' },
            { step: '04', icon: '🔄', title: 'Atualização contínua', desc: 'O conteúdo é revisado periodicamente para refletir novas evidências científicas.' },
          ].map(item => (
            <div style="background: #F4F8FC; border-radius: 14px; padding: 1.5rem;">
              <div style="font-size: 1.5rem; margin-bottom: 0.75rem;">{item.icon}</div>
              <p style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #1DB8E8; margin: 0 0 0.4rem;">{item.step}</p>
              <h3 style="font-family: 'Sora', system-ui, sans-serif; font-size: 0.95rem; font-weight: 700; color: #0D1B3E; margin: 0 0 0.5rem;">{item.title}</h3>
              <p style="font-size: 0.85rem; color: #6B7A9A; line-height: 1.6; margin: 0;">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- Disclaimer editorial -->
        <div style="margin-top: 2rem; padding: 1rem 1.25rem; background: #FFF8E7; border: 1px solid #F5D170; border-radius: 10px; display: flex; gap: 0.75rem; align-items: flex-start;">
          <span style="font-size: 1.1rem; flex-shrink: 0;">⚠️</span>
          <p style="font-size: 0.82rem; color: #7A5900; line-height: 1.55; margin: 0;">
            <strong>Aviso importante:</strong> O conteúdo do Zen Caps Blog tem finalidade educacional e informativa. Não substitui o diagnóstico, tratamento ou aconselhamento de médico, nutricionista ou outro profissional de saúde habilitado. Consulte sempre um especialista antes de iniciar qualquer suplementação ou mudança de estilo de vida.
          </p>
        </div>
      </div>
    </section>

    <!-- Equipe -->
    <section style="padding: 4rem 1.5rem;">
      <div style="max-width: 720px; margin: 0 auto;">
        <h2 style="font-family: 'Sora', system-ui, sans-serif; font-size: 1.5rem; font-weight: 800; color: #0D1B3E; margin-bottom: 0.5rem; text-align: center;">
          Nossa equipe de especialistas
        </h2>
        <p style="text-align: center; color: #6B7A9A; font-size: 0.95rem; margin-bottom: 3rem;">
          Cada especialista revisa os artigos da sua área de atuação.
        </p>

        <div style="display: flex; flex-direction: column; gap: 2rem;">
          {team.map(member => (
            <div id={member.id} style={`background: #FFFFFF; border: 1px solid #e8eef6; border-radius: 18px; padding: 2rem; border-left: 4px solid ${member.color};`}>
              <div style="display: flex; align-items: flex-start; gap: 1.25rem; flex-wrap: wrap;">
                <!-- Avatar -->
                <div style={`width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, ${member.color}33 0%, ${member.color}11 100%); border: 2px solid ${member.color}44; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.75rem;`}>
                  {member.emoji}
                </div>
                <!-- Info -->
                <div style="flex: 1; min-width: 200px;">
                  <h3 style="font-family: 'Sora', system-ui, sans-serif; font-size: 1.1rem; font-weight: 800; color: #0D1B3E; margin: 0 0 0.2rem;">
                    {member.name}
                  </h3>
                  <p style={`font-size: 0.8rem; font-weight: 600; color: ${member.color}; margin: 0 0 0.75rem;`}>
                    {member.title}
                  </p>
                  <p style="font-size: 0.9rem; color: #3A4A6B; line-height: 1.65; margin: 0 0 1rem;">
                    {member.bio}
                  </p>
                  <!-- Áreas de atuação -->
                  <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
                    {member.areas.map(area => (
                      <span style={`font-size: 0.72rem; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: ${member.color}15; color: ${member.color};`}>
                        {area}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA voltar ao blog -->
    <section style="padding: 0 1.5rem 5rem;">
      <div style="max-width: 720px; margin: 0 auto; text-align: center;">
        <a
          href="/blog"
          style="display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 700; color: #1DB8E8; text-decoration: none; font-size: 0.95rem;"
          onmouseover="this.style.color='#0D1B3E'"
          onmouseout="this.style.color='#1DB8E8'"
        >
          &larr; Voltar para o blog
        </a>
      </div>
    </section>

  </div>
</BlogLayout>
