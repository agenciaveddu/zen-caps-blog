---
import BlogLayout from '../../layouts/BlogLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Quiz do Sono — Zen Caps',
  description: 'Descubra o que está sabotando seu sono com este quiz gratuito de 8 perguntas baseado em ciência.',
  url: 'https://zencaps.com.br/blog/quiz-do-sono/',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'BRL' },
  author: { '@type': 'Organization', name: 'Zen Caps', url: 'https://zencaps.com.br' },
}
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://zencaps.com.br/blog/' },
    { '@type': 'ListItem', position: 2, name: 'Quiz do Sono', item: 'https://zencaps.com.br/blog/quiz-do-sono/' },
  ],
}
---

<BlogLayout
  title="Quiz do Sono: Descubra o Que Está Sabotando Seu Descanso | Zen Caps"
  description="Faça o quiz gratuito de 8 perguntas e descubra seu score de qualidade do sono. Baseado em ciência, com recomendações personalizadas."
  canonical="https://zencaps.com.br/blog/quiz-do-sono/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <style is:inline>
    /* ===== QUIZ GLOBAL STYLES ===== */
    .qz-wrap { background: linear-gradient(180deg, #0a1628 0%, #0D1B3E 50%, #111d3a 100%); min-height: 100vh; font-family: 'DM Sans', system-ui, sans-serif; overflow-x: hidden; }
    .qz-container { max-width: 540px; margin: 0 auto; padding: 0 1.25rem; }

    /* Progress bar */
    .qz-progress { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 4px; background: rgba(255,255,255,0.08); }
    .qz-progress-fill { height: 100%; background: linear-gradient(90deg, #1DB8E8, #5DD4F4); border-radius: 0 2px 2px 0; transition: width 0.6s cubic-bezier(0.4,0,0.2,1); }

    /* Top bar */
    .qz-topbar { display: flex; align-items: center; justify-content: space-between; padding: 1rem 0 0.5rem; }
    .qz-topbar-back { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 8px; border-radius: 8px; transition: all 0.2s; display: flex; align-items: center; }
    .qz-topbar-back:hover { color: #fff; background: rgba(255,255,255,0.08); }
    .qz-topbar-step { font-family: 'Sora', sans-serif; font-size: 0.72rem; font-weight: 700; color: rgba(255,255,255,0.35); letter-spacing: 0.1em; text-transform: uppercase; }

    /* Screens */
    .qz-screen { display: none; }
    .qz-screen.active { display: block; animation: qzSlideIn 0.4s cubic-bezier(0.4,0,0.2,1); }
    @keyframes qzSlideIn { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
    @keyframes qzFadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes qzPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    @keyframes qzSpin { to { transform: rotate(360deg); } }
    @keyframes qzCountUp { from { opacity: 0; transform: scale(0.5); } to { opacity: 1; transform: scale(1); } }

    /* Question */
    .qz-question { font-family: 'Sora', sans-serif; font-size: 1.25rem; font-weight: 800; color: #ffffff; line-height: 1.35; margin: 1.5rem 0 1.75rem; }

    /* Option cards */
    .qz-option {
      display: flex; align-items: center; gap: 14px; width: 100%;
      padding: 16px 20px; margin-bottom: 10px;
      background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.08);
      border-radius: 14px; cursor: pointer; transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
      color: rgba(255,255,255,0.8); font-size: 0.95rem; text-align: left;
      font-family: 'DM Sans', system-ui, sans-serif;
    }
    .qz-option:hover { background: rgba(29,184,232,0.08); border-color: rgba(29,184,232,0.3); transform: translateX(4px); }
    .qz-option.selected { background: rgba(29,184,232,0.12); border-color: #1DB8E8; color: #fff; transform: scale(1.02); }
    .qz-option .qz-opt-icon {
      width: 40px; height: 40px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.25rem; flex-shrink: 0;
      background: rgba(255,255,255,0.06); transition: all 0.25s;
    }
    .qz-option.selected .qz-opt-icon { background: #1DB8E8; }
    .qz-option .qz-opt-text { font-weight: 500; line-height: 1.4; }
    .qz-option.selected .qz-opt-text { font-weight: 700; }
    .qz-option .qz-opt-check { margin-left: auto; opacity: 0; transition: opacity 0.2s; flex-shrink: 0; }
    .qz-option.selected .qz-opt-check { opacity: 1; }

    /* Start screen */
    .qz-hero { text-align: center; padding: 3rem 0 2rem; }
    .qz-hero-icon { font-size: 4rem; margin-bottom: 1rem; animation: qzPulse 3s ease-in-out infinite; display: inline-block; }
    .qz-hero h1 { font-family: 'Sora', sans-serif; font-size: clamp(1.6rem, 5vw, 2.2rem); font-weight: 900; color: #fff; line-height: 1.15; margin: 0 0 0.75rem; }
    .qz-hero h1 span { color: #1DB8E8; }
    .qz-hero p { font-size: 1rem; color: rgba(255,255,255,0.5); line-height: 1.7; margin: 0 0 2rem; max-width: 400px; margin-left: auto; margin-right: auto; }
    .qz-features { display: flex; flex-direction: column; gap: 12px; margin-bottom: 2rem; text-align: left; max-width: 340px; margin-left: auto; margin-right: auto; }
    .qz-feature { display: flex; align-items: center; gap: 12px; padding: 10px 16px; background: rgba(29,184,232,0.06); border: 1px solid rgba(29,184,232,0.12); border-radius: 12px; }
    .qz-feature-icon { font-size: 1.2rem; }
    .qz-feature-text { font-size: 0.88rem; color: rgba(255,255,255,0.7); }
    .qz-feature-text strong { color: #fff; }

    /* CTA button */
    .qz-cta {
      width: 100%; padding: 18px 24px; border: none; border-radius: 14px;
      font-family: 'Sora', sans-serif; font-weight: 800; font-size: 1.05rem;
      cursor: pointer; transition: all 0.3s; position: relative; overflow: hidden;
      background: linear-gradient(135deg, #1DB8E8, #5DD4F4); color: #fff;
      box-shadow: 0 8px 32px rgba(29,184,232,0.35);
    }
    .qz-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(29,184,232,0.5); }
    .qz-cta:active { transform: translateY(0); }
    .qz-cta-gold { background: linear-gradient(135deg, #C9A84C, #e8c96a); box-shadow: 0 8px 32px rgba(201,168,76,0.35); }
    .qz-cta-gold:hover { box-shadow: 0 12px 40px rgba(201,168,76,0.5); }

    /* Social proof */
    .qz-social { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 1.25rem; }
    .qz-social-avatars { display: flex; }
    .qz-social-avatars span { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; border: 2px solid #0D1B3E; margin-left: -8px; }
    .qz-social-avatars span:first-child { margin-left: 0; }
    .qz-social-text { font-size: 0.75rem; color: rgba(255,255,255,0.4); }
    .qz-social-text strong { color: rgba(255,255,255,0.6); }

    /* Interstitial */
    .qz-interstitial { text-align: center; padding: 4rem 0; }
    .qz-interstitial-icon { font-size: 3rem; margin-bottom: 1.5rem; display: inline-block; }
    .qz-interstitial h2 { font-family: 'Sora', sans-serif; font-size: 1.3rem; font-weight: 800; color: #fff; margin: 0 0 0.75rem; line-height: 1.3; }
    .qz-interstitial p { font-size: 0.95rem; color: rgba(255,255,255,0.55); line-height: 1.7; margin: 0; max-width: 380px; margin-left: auto; margin-right: auto; }
    .qz-stat { display: inline-block; font-family: 'Sora', sans-serif; font-size: 2.5rem; font-weight: 900; background: linear-gradient(135deg, #1DB8E8, #5DD4F4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem; }

    /* Loading screen */
    .qz-loading { text-align: center; padding: 4rem 0; }
    .qz-spinner { width: 60px; height: 60px; border: 3px solid rgba(29,184,232,0.15); border-top-color: #1DB8E8; border-radius: 50%; animation: qzSpin 0.8s linear infinite; margin: 0 auto 2rem; }
    .qz-loading-steps { display: flex; flex-direction: column; gap: 14px; max-width: 300px; margin: 0 auto; text-align: left; }
    .qz-loading-step { display: flex; align-items: center; gap: 12px; font-size: 0.88rem; color: rgba(255,255,255,0.3); transition: color 0.5s; }
    .qz-loading-step.done { color: rgba(255,255,255,0.8); }
    .qz-loading-step .qz-check { width: 22px; height: 22px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; transition: all 0.5s; flex-shrink: 0; }
    .qz-loading-step.done .qz-check { border-color: #1DB8E8; background: #1DB8E8; color: #fff; }

    /* Email gate */
    .qz-email-gate { padding: 2rem 0; }
    .qz-email-preview { position: relative; margin-bottom: 2rem; }
    .qz-email-blur { filter: blur(8px); pointer-events: none; opacity: 0.5; }
    .qz-email-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; }
    .qz-email-lock { background: rgba(13,27,62,0.9); border: 1px solid rgba(29,184,232,0.2); border-radius: 16px; padding: 1.5rem 2rem; text-align: center; backdrop-filter: blur(4px); }
    .qz-email-lock p { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin: 0.5rem 0 0; }
    .qz-input { width: 100%; padding: 16px 20px; border: 2px solid rgba(255,255,255,0.1); border-radius: 12px; font-family: 'DM Sans', sans-serif; font-size: 0.95rem; color: #fff; outline: none; transition: border-color 0.2s; background: rgba(255,255,255,0.04); box-sizing: border-box; }
    .qz-input::placeholder { color: rgba(255,255,255,0.25); }
    .qz-input:focus { border-color: #1DB8E8; background: rgba(29,184,232,0.04); }
    .qz-input.error { border-color: #e74c3c; }
    .qz-skip { background: none; border: none; color: rgba(255,255,255,0.3); font-size: 0.78rem; cursor: pointer; margin-top: 1rem; font-family: 'DM Sans', sans-serif; transition: color 0.2s; }
    .qz-skip:hover { color: rgba(255,255,255,0.6); }

    /* Result */
    .qz-result { padding: 1rem 0 3rem; }
    .qz-score-wrap { text-align: center; margin-bottom: 2rem; }
    .qz-score-ring { position: relative; width: 200px; height: 200px; margin: 0 auto 1rem; }
    .qz-score-ring svg { transform: rotate(-90deg); }
    .qz-score-val { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; }
    .qz-score-num { font-family: 'Sora', sans-serif; font-size: 3rem; font-weight: 900; animation: qzCountUp 0.8s ease-out; }
    .qz-score-label { font-size: 0.75rem; color: rgba(255,255,255,0.4); }
    .qz-level-badge { display: inline-flex; align-items: center; gap: 6px; padding: 8px 20px; border-radius: 24px; font-family: 'Sora', sans-serif; font-weight: 700; font-size: 0.88rem; }
    .qz-level-desc { font-size: 0.95rem; color: rgba(255,255,255,0.6); line-height: 1.7; text-align: center; margin: 1rem 0 2rem; max-width: 440px; margin-left: auto; margin-right: auto; }

    /* Cause cards */
    .qz-cause { padding: 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; margin-bottom: 12px; }
    .qz-cause-head { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
    .qz-cause-icon { font-size: 1.2rem; }
    .qz-cause-name { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 0.92rem; color: #fff; }
    .qz-cause-tip { font-size: 0.85rem; color: rgba(255,255,255,0.5); line-height: 1.6; margin: 0 0 6px; }
    .qz-cause-link { font-size: 0.82rem; color: #1DB8E8; text-decoration: none; font-weight: 600; }
    .qz-cause-link:hover { text-decoration: underline; }

    /* Product CTA */
    .qz-product { background: linear-gradient(135deg, rgba(29,184,232,0.1), rgba(29,184,232,0.04)); border: 1px solid rgba(29,184,232,0.2); border-radius: 18px; padding: 2rem; text-align: center; margin: 2rem 0; }
    .qz-product h3 { font-family: 'Sora', sans-serif; font-size: 1.1rem; font-weight: 800; color: #fff; margin: 0 0 0.5rem; }
    .qz-product p { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin: 0 0 1.25rem; }
    .qz-product-pills { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 1.25rem; }
    .qz-pill { padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; background: rgba(29,184,232,0.1); color: #1DB8E8; border: 1px solid rgba(29,184,232,0.2); }

    /* SEO section */
    .qz-seo { padding: 3rem 1.5rem; background: #F4F8FC; }
    .qz-seo-card { max-width: 680px; margin: 0 auto 2rem; background: #fff; border-radius: 18px; padding: 2rem; border: 1px solid #e8eef6; }
    .qz-seo-card h2 { font-family: 'Sora', sans-serif; font-size: 1.3rem; font-weight: 800; color: #0D1B3E; margin: 0 0 1rem; }
    .qz-seo-card p { font-size: 0.95rem; color: #3A4A6B; line-height: 1.8; margin: 0 0 1rem; }
    .qz-seo-card p:last-child { margin-bottom: 0; }
    .qz-seo-links { max-width: 680px; margin: 0 auto 2rem; background: #fff; border-radius: 18px; padding: 2rem; border: 1px solid #e8eef6; }
    .qz-seo-links h3 { font-family: 'Sora', sans-serif; font-size: 1.1rem; font-weight: 700; color: #0D1B3E; margin: 0 0 1rem; }
    .qz-seo-links a { color: #1DB8E8; text-decoration: none; font-weight: 600; font-size: 0.92rem; display: block; padding: 6px 0; }
    .qz-seo-links a:hover { text-decoration: underline; }

    @media (max-width: 480px) {
      .qz-question { font-size: 1.1rem; }
      .qz-score-ring { width: 160px; height: 160px; }
      .qz-score-num { font-size: 2.4rem; }
      .qz-option { padding: 14px 16px; }
    }
  </style>

  <!-- ===== QUIZ FULLSCREEN ===== -->
  <div class="qz-wrap" id="quiz-app">

    <!-- Progress bar -->
    <div class="qz-progress"><div class="qz-progress-fill" id="qz-progress" style="width: 0%;"></div></div>

    <div class="qz-container">

      <!-- Top bar (hidden on start) -->
      <div class="qz-topbar" id="qz-topbar" style="visibility: hidden;">
        <button type="button" class="qz-topbar-back" id="qz-back" onclick="qzPrev()">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="qz-topbar-step" id="qz-step"></span>
        <a href="/blog/" style="font-size: 0.72rem; color: rgba(255,255,255,0.25); text-decoration: none;">Sair</a>
      </div>

      <!-- SCREEN: Start -->
      <div class="qz-screen active" id="scr-start">
        <div class="qz-hero">
          <span class="qz-hero-icon">🌙</span>
          <h1>O Que Está<br/>Sabotando Seu <span>Sono</span>?</h1>
          <p>Responda 8 perguntas rápidas e receba um diagnóstico personalizado do seu sono.</p>

          <div class="qz-features">
            <div class="qz-feature">
              <span class="qz-feature-icon">📊</span>
              <span class="qz-feature-text"><strong>Score de 0 a 100</strong> baseado em ciência</span>
            </div>
            <div class="qz-feature">
              <span class="qz-feature-icon">🔍</span>
              <span class="qz-feature-text">Identifica suas <strong>3 principais causas</strong></span>
            </div>
            <div class="qz-feature">
              <span class="qz-feature-icon">💡</span>
              <span class="qz-feature-text"><strong>Plano personalizado</strong> para dormir melhor</span>
            </div>
          </div>

          <button type="button" class="qz-cta" onclick="qzStart()">
            Descobrir meu score do sono
          </button>

          <div class="qz-social">
            <div class="qz-social-avatars">
              <span style="background:#5DD4F4;">👩</span>
              <span style="background:#C9A84C;">👨</span>
              <span style="background:#5B6FDE;">👩</span>
              <span style="background:#0fa36b;">👨</span>
            </div>
            <span class="qz-social-text"><strong>2.847 pessoas</strong> fizeram este quiz</span>
          </div>
        </div>
      </div>

      <!-- SCREEN: Questions (rendered dynamically) -->
      <div class="qz-screen" id="scr-question">
        <h2 class="qz-question" id="qz-question"></h2>
        <div id="qz-options"></div>
      </div>

      <!-- SCREEN: Interstitial 1 (after Q3) -->
      <div class="qz-screen" id="scr-inter1">
        <div class="qz-interstitial">
          <span class="qz-interstitial-icon">🔬</span>
          <h2>Estamos analisando suas respostas...</h2>
          <p>Já identificamos padrões importantes. Mais 5 perguntas para completar seu perfil.</p>
        </div>
      </div>

      <!-- SCREEN: Interstitial 2 (after Q6) -->
      <div class="qz-screen" id="scr-inter2">
        <div class="qz-interstitial">
          <div class="qz-stat">87%</div>
          <h2>das pessoas com perfil similar melhoraram o sono em 30 dias</h2>
          <p>Quase lá! Mais 2 perguntas para finalizar seu diagnóstico.</p>
        </div>
      </div>

      <!-- SCREEN: Loading / Analysis -->
      <div class="qz-screen" id="scr-loading">
        <div class="qz-loading">
          <div class="qz-spinner"></div>
          <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:800; color:#fff; margin:0 0 2rem;">Analisando seu perfil de sono...</h2>
          <div class="qz-loading-steps">
            <div class="qz-loading-step" id="load-1"><span class="qz-check">✓</span> Calculando score de qualidade</div>
            <div class="qz-loading-step" id="load-2"><span class="qz-check">✓</span> Identificando causas raiz</div>
            <div class="qz-loading-step" id="load-3"><span class="qz-check">✓</span> Gerando recomendações personalizadas</div>
          </div>
        </div>
      </div>

      <!-- SCREEN: Email Gate -->
      <div class="qz-screen" id="scr-email">
        <div class="qz-email-gate">
          <div style="text-align:center; margin-bottom:2rem;">
            <span style="font-size:2.5rem; display:inline-block; margin-bottom:0.75rem;">🎯</span>
            <h2 style="font-family:'Sora',sans-serif; font-size:1.25rem; font-weight:800; color:#fff; margin:0 0 0.5rem;">Seu diagnóstico está pronto!</h2>
            <p style="font-size:0.9rem; color:rgba(255,255,255,0.5); line-height:1.6; margin:0;">Para onde enviamos seu relatório completo?</p>
          </div>

          <!-- Blurred preview -->
          <div class="qz-email-preview">
            <div class="qz-email-blur" id="qz-blur-preview"></div>
            <div class="qz-email-overlay">
              <div class="qz-email-lock">
                <span style="font-size:1.5rem;">🔒</span>
                <p>Informe seu email para desbloquear</p>
              </div>
            </div>
          </div>

          <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:1rem;">
            <input type="text" id="qz-name" class="qz-input" placeholder="Seu primeiro nome" />
            <input type="email" id="qz-email" class="qz-input" placeholder="Seu melhor email" />
          </div>
          <button type="button" class="qz-cta" onclick="qzSubmitEmail()" id="qz-btn-email">
            Ver meu resultado completo
          </button>
          <div style="text-align:center;">
            <button type="button" class="qz-skip" onclick="qzSkipEmail()">Pular e ver resultado resumido</button>
          </div>
          <p style="font-size:0.68rem; color:rgba(255,255,255,0.2); text-align:center; margin:1rem 0 0; line-height:1.5;">
            Seus dados estão seguros. Sem spam. Cancele quando quiser.
          </p>
        </div>
      </div>

      <!-- SCREEN: Result -->
      <div class="qz-screen" id="scr-result">
        <div class="qz-result" id="qz-result-content"></div>
      </div>

    </div>
  </div>

  <!-- SEO content below quiz -->
  <div class="qz-seo">
    <div class="qz-seo-card">
      <h2>Por que fazer este quiz?</h2>
      <p>Dormir mal vai muito além do cansaço. O sono ruim crônico afeta memória, metabolismo, humor e até expectativa de vida. O problema é que a maioria das pessoas não sabe <strong>o que exatamente</strong> está prejudicando seu sono.</p>
      <p>Este quiz foi criado com base em pesquisas de neurociência do sono para identificar os fatores mais comuns que comprometem a qualidade do descanso — desde hábitos noturnos até deficiências nutricionais.</p>
    </div>
    <div class="qz-seo-links">
      <h3>Artigos relacionados</h3>
      <a href="/blog/como-dormir-melhor-guia-completo/">Como dormir melhor: guia completo</a>
      <a href="/blog/por-que-voce-acorda-cansado-mesmo-dormindo-8-horas/">Por que você acorda cansado mesmo dormindo 8 horas</a>
      <a href="/blog/calculadora-de-sono/">Calculadora de Sono gratuita</a>
      <a href="/blog/ansiedade-noturna-como-tratar/">Por que a ansiedade piora à noite</a>
    </div>
    <div style="text-align:center; padding-bottom:3rem;">
      <a href="/blog/" style="font-weight:700; color:#1DB8E8; text-decoration:none; font-size:0.95rem;">← Voltar para o blog</a>
    </div>
  </div>

  <script is:inline>
    /* ===== DATA ===== */
    const QZ = {
      questions: [
        { q: 'Quanto tempo você demora para adormecer depois de deitar?', icon: '⏱️',
          opts: [
            { text: 'Menos de 15 minutos', icon: '😴', score: 3 },
            { text: 'Entre 15 e 30 minutos', icon: '🥱', score: 2 },
            { text: 'Entre 30 e 60 minutos', icon: '😩', score: 1 },
            { text: 'Mais de 1 hora', icon: '😰', score: 0 },
          ], cat: 'latencia' },
        { q: 'Quantas vezes você acorda durante a noite?', icon: '🌃',
          opts: [
            { text: 'Nenhuma — durmo direto', icon: '✨', score: 3 },
            { text: '1 vez', icon: '1️⃣', score: 2 },
            { text: '2 a 3 vezes', icon: '😫', score: 1 },
            { text: 'Mais de 3 vezes', icon: '💀', score: 0 },
          ], cat: 'fragmentacao' },
        { q: 'Como você se sente ao acordar pela manhã?', icon: '🌅',
          opts: [
            { text: 'Descansado e com energia', icon: '⚡', score: 3 },
            { text: 'Preciso de um tempo para "ligar"', icon: '☕', score: 2 },
            { text: 'Cansado, como se não tivesse dormido', icon: '😪', score: 1 },
            { text: 'Exausto, mesmo dormindo muitas horas', icon: '🧟', score: 0 },
          ], cat: 'qualidade' },
        { q: 'Você usa celular ou telas nos 30 min antes de dormir?', icon: '📱',
          opts: [
            { text: 'Nunca ou raramente', icon: '📕', score: 3 },
            { text: 'Às vezes (2-3x por semana)', icon: '🤷', score: 2 },
            { text: 'Quase sempre', icon: '📲', score: 1 },
            { text: 'Sempre — durmo com o celular', icon: '🤳', score: 0 },
          ], cat: 'telas' },
        { q: 'Em que horário você consome sua última cafeína?', icon: '☕',
          opts: [
            { text: 'Antes das 14h ou não consumo', icon: '🌤️', score: 3 },
            { text: 'Entre 14h e 17h', icon: '🌇', score: 2 },
            { text: 'Entre 17h e 20h', icon: '🌆', score: 1 },
            { text: 'Depois das 20h', icon: '🌙', score: 0 },
          ], cat: 'cafeina' },
        { q: 'Você sente ansiedade ou pensamentos acelerados ao deitar?', icon: '🧠',
          opts: [
            { text: 'Nunca ou raramente', icon: '😌', score: 3 },
            { text: 'Às vezes (1-2x por semana)', icon: '😐', score: 2 },
            { text: 'Frequentemente (3-5x)', icon: '😟', score: 1 },
            { text: 'Todas as noites', icon: '😣', score: 0 },
          ], cat: 'ansiedade' },
        { q: 'Como é seu quarto na hora de dormir?', icon: '🛏️',
          opts: [
            { text: 'Escuro, silencioso e fresco', icon: '🌑', score: 3 },
            { text: 'Razoável, mas poderia melhorar', icon: '🌗', score: 2 },
            { text: 'Com alguma luz e/ou barulho', icon: '🌕', score: 1 },
            { text: 'Claro, barulhento ou quente', icon: '🔆', score: 0 },
          ], cat: 'ambiente' },
        { q: 'Você pratica atividade física regularmente?', icon: '🏃',
          opts: [
            { text: '4+ vezes por semana', icon: '💪', score: 3 },
            { text: '2-3 vezes por semana', icon: '🚶', score: 2 },
            { text: 'Raramente (1x ou menos)', icon: '🛋️', score: 1 },
            { text: 'Não pratico', icon: '😶', score: 0 },
          ], cat: 'exercicio' },
      ],
      interstitials: { 3: 'scr-inter1', 6: 'scr-inter2' },
      current: 0,
      answers: [],
      hasEmail: false,
    };

    QZ.answers = new Array(QZ.questions.length).fill(-1);

    const causeData = {
      latencia:     { name: 'Dificuldade para adormecer', icon: '⏱️', tip: 'Técnicas de respiração 4-7-8 e redução de estímulos 1h antes podem reduzir a latência do sono.', link: '/blog/nao-consigo-dormir-o-que-fazer/' },
      fragmentacao: { name: 'Sono fragmentado', icon: '💔', tip: 'Despertares frequentes impedem os ciclos de sono profundo. Magnésio e ambiente adequado ajudam.', link: '/blog/despertar-de-madrugada-causas-solucoes/' },
      qualidade:    { name: 'Baixa qualidade restauradora', icon: '🔋', tip: 'Você dorme mas não descansa. O problema está na arquitetura dos ciclos de sono.', link: '/blog/por-que-voce-acorda-cansado-mesmo-dormindo-8-horas/' },
      telas:        { name: 'Excesso de telas antes de dormir', icon: '📱', tip: 'A luz azul suprime melatonina em até 50%. Celular antes de dormir é o maior sabotador.', link: '/blog/celular-antes-de-dormir-prejudica-sono/' },
      cafeina:      { name: 'Cafeína tardia', icon: '☕', tip: 'A cafeína tem meia-vida de 6h. Um café às 16h ainda tem 50% de efeito às 22h.', link: '/blog/cafeina-e-sono-quanto-afeta/' },
      ansiedade:    { name: 'Ansiedade noturna', icon: '🧠', tip: 'Pensamentos acelerados indicam hiperativação do sistema nervoso. Triptofano e magnésio ajudam.', link: '/blog/ansiedade-noturna-como-tratar/' },
      ambiente:     { name: 'Ambiente inadequado', icon: '🌡️', tip: 'Temperatura, luz e ruído afetam o sono profundo. O ideal é escuro, silencioso e 18-21°C.', link: '/blog/temperatura-do-quarto-ideal-para-dormir/' },
      exercicio:    { name: 'Sedentarismo', icon: '🏃', tip: 'Exercício regular melhora o sono profundo em até 65%. Caminhadas de 30 min já fazem diferença.', link: '/blog/exercicio-fisico-melhora-sono/' },
    };

    /* ===== SCREEN MANAGEMENT ===== */
    function qzShowScreen(id) {
      document.querySelectorAll('.qz-screen').forEach(el => el.classList.remove('active'));
      document.getElementById(id).classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function qzUpdateProgress() {
      const pct = Math.round(((QZ.current + 1) / QZ.questions.length) * 100);
      document.getElementById('qz-progress').style.width = pct + '%';
      document.getElementById('qz-step').textContent = `${QZ.current + 1} de ${QZ.questions.length}`;
    }

    /* ===== START ===== */
    function qzStart() {
      document.getElementById('qz-topbar').style.visibility = 'visible';
      QZ.current = 0;
      qzUpdateProgress();
      qzRenderQuestion();
      qzShowScreen('scr-question');
    }

    /* ===== RENDER QUESTION ===== */
    function qzRenderQuestion() {
      const q = QZ.questions[QZ.current];
      document.getElementById('qz-question').textContent = q.q;
      qzUpdateProgress();

      const wrap = document.getElementById('qz-options');
      wrap.innerHTML = '';

      q.opts.forEach(function(opt, i) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'qz-option' + (QZ.answers[QZ.current] === i ? ' selected' : '');

        var iconDiv = document.createElement('span');
        iconDiv.className = 'qz-opt-icon';
        iconDiv.textContent = opt.icon;

        var textDiv = document.createElement('span');
        textDiv.className = 'qz-opt-text';
        textDiv.textContent = opt.text;

        var checkDiv = document.createElement('span');
        checkDiv.className = 'qz-opt-check';
        checkDiv.textContent = '✓';

        btn.appendChild(iconDiv);
        btn.appendChild(textDiv);
        btn.appendChild(checkDiv);

        btn.addEventListener('click', function() { qzSelect(i); });
        wrap.appendChild(btn);
      });
    }

    /* ===== SELECT OPTION (auto-advance) ===== */
    function qzSelect(i) {
      QZ.answers[QZ.current] = i;

      // Visual feedback
      document.querySelectorAll('.qz-option').forEach(function(el, idx) {
        el.classList.toggle('selected', idx === i);
      });

      // Auto-advance after brief delay
      setTimeout(function() {
        qzNext();
      }, 400);
    }

    /* ===== NAVIGATION ===== */
    function qzNext() {
      if (QZ.current < QZ.questions.length - 1) {
        QZ.current++;
        // Check for interstitial
        if (QZ.interstitials[QZ.current]) {
          qzShowScreen(QZ.interstitials[QZ.current]);
          setTimeout(function() {
            qzRenderQuestion();
            qzShowScreen('scr-question');
          }, 2200);
        } else {
          qzRenderQuestion();
          qzShowScreen('scr-question');
        }
      } else {
        // Last question answered — show loading
        qzShowLoading();
      }
    }

    function qzPrev() {
      if (QZ.current > 0) {
        QZ.current--;
        qzUpdateProgress();
        qzRenderQuestion();
        qzShowScreen('scr-question');
      } else {
        document.getElementById('qz-topbar').style.visibility = 'hidden';
        qzShowScreen('scr-start');
        document.getElementById('qz-progress').style.width = '0%';
      }
    }

    /* ===== LOADING ANIMATION ===== */
    function qzShowLoading() {
      document.getElementById('qz-progress').style.width = '100%';
      qzShowScreen('scr-loading');

      var steps = ['load-1', 'load-2', 'load-3'];
      steps.forEach(function(id, idx) {
        setTimeout(function() {
          document.getElementById(id).classList.add('done');
        }, 800 * (idx + 1));
      });

      setTimeout(function() {
        qzShowEmailGate();
      }, 3200);
    }

    /* ===== SCORE CALCULATION ===== */
    function qzCalcScore() {
      var total = 0;
      for (var i = 0; i < QZ.answers.length; i++) {
        total += QZ.questions[i].opts[QZ.answers[i]].score;
      }
      return Math.round((total / (QZ.questions.length * 3)) * 100);
    }

    function qzGetLevel(score) {
      if (score >= 80) return { label: 'Sono Saudável', color: '#0fa36b', bg: 'rgba(15,163,107,0.12)', border: 'rgba(15,163,107,0.3)', emoji: '🟢', desc: 'Seu sono está em boa forma! Pequenos ajustes podem torná-lo ainda melhor.' };
      if (score >= 55) return { label: 'Sono Comprometido', color: '#C9A84C', bg: 'rgba(201,168,76,0.12)', border: 'rgba(201,168,76,0.3)', emoji: '🟡', desc: 'Alguns fatores estão prejudicando a qualidade do seu sono. A boa notícia: são corrigíveis.' };
      if (score >= 30) return { label: 'Sono Ruim', color: '#e67e22', bg: 'rgba(230,126,34,0.12)', border: 'rgba(230,126,34,0.3)', emoji: '🟠', desc: 'Seu sono está significativamente comprometido. Múltiplos fatores estão atuando contra você.' };
      return { label: 'Sono Crítico', color: '#e74c3c', bg: 'rgba(231,76,60,0.12)', border: 'rgba(231,76,60,0.3)', emoji: '🔴', desc: 'Seu sono precisa de atenção urgente. Os padrões identificados afetam diretamente sua saúde e bem-estar.' };
    }

    function qzGetCauses() {
      var catScores = {};
      for (var i = 0; i < QZ.answers.length; i++) {
        catScores[QZ.questions[i].cat] = QZ.questions[i].opts[QZ.answers[i]].score;
      }
      var sorted = Object.entries(catScores).sort(function(a, b) { return a[1] - b[1]; });
      var worst = sorted.filter(function(s) { return s[1] <= 1; }).slice(0, 3);
      return worst.length === 0 ? sorted.slice(0, 2) : worst;
    }

    /* ===== EMAIL GATE ===== */
    function qzShowEmailGate() {
      var score = qzCalcScore();
      var level = qzGetLevel(score);

      // Build blurred preview
      var r = 60, circ = 2 * Math.PI * r, offset = circ - (score / 100) * circ;
      document.getElementById('qz-blur-preview').innerHTML =
        '<div style="text-align:center;padding:2rem 1rem;">' +
          '<svg width="140" height="140" style="transform:rotate(-90deg);">' +
            '<circle cx="70" cy="70" r="' + r + '" stroke="rgba(255,255,255,0.08)" stroke-width="8" fill="none"/>' +
            '<circle cx="70" cy="70" r="' + r + '" stroke="' + level.color + '" stroke-width="8" fill="none" stroke-dasharray="' + circ + '" stroke-dashoffset="' + offset + '" stroke-linecap="round"/>' +
          '</svg>' +
          '<div style="font-family:Sora,sans-serif;font-size:1.5rem;font-weight:900;color:' + level.color + ';margin-top:-90px;position:relative;">' + score + '</div>' +
          '<div style="font-size:0.7rem;color:rgba(255,255,255,0.3);margin-top:55px;">de 100</div>' +
          '<div style="margin-top:1rem;display:inline-block;padding:6px 14px;border-radius:16px;background:' + level.bg + ';border:1px solid ' + level.border + ';font-size:0.8rem;font-weight:700;color:' + level.color + ';">' + level.emoji + ' ' + level.label + '</div>' +
        '</div>';

      qzShowScreen('scr-email');
    }

    function qzSubmitEmail() {
      var name = document.getElementById('qz-name').value.trim();
      var email = document.getElementById('qz-email').value.trim();
      if (!email || !email.includes('@') || !email.includes('.')) {
        document.getElementById('qz-email').classList.add('error');
        return;
      }
      document.getElementById('qz-email').classList.remove('error');
      QZ.hasEmail = true;

      // Save lead
      try {
        var leads = JSON.parse(localStorage.getItem('zc_leads') || '[]');
        leads.push({ name: name, email: email, quiz: 'sono', score: qzCalcScore(), ts: new Date().toISOString() });
        localStorage.setItem('zc_leads', JSON.stringify(leads));
      } catch(e) {}

      qzShowResult(true, name);
    }

    function qzSkipEmail() {
      qzShowResult(false, '');
    }

    /* ===== RESULT ===== */
    function qzShowResult(full, userName) {
      var score = qzCalcScore();
      var level = qzGetLevel(score);
      var causes = qzGetCauses();

      var r = 88, circ = 2 * Math.PI * r, offset = circ - (score / 100) * circ;

      var html = '';

      // Greeting
      if (userName) {
        html += '<p style="text-align:center;font-size:0.85rem;color:rgba(255,255,255,0.4);margin:0 0 0.25rem;">Resultado de</p>';
        html += '<p style="text-align:center;font-family:Sora,sans-serif;font-size:1.1rem;font-weight:700;color:#fff;margin:0 0 1.5rem;">' + userName + '</p>';
      }

      // Score ring
      html += '<div class="qz-score-wrap">' +
        '<div class="qz-score-ring">' +
          '<svg width="200" height="200">' +
            '<circle cx="100" cy="100" r="' + r + '" stroke="rgba(255,255,255,0.06)" stroke-width="10" fill="none"/>' +
            '<circle cx="100" cy="100" r="' + r + '" stroke="' + level.color + '" stroke-width="10" fill="none" stroke-dasharray="' + circ + '" stroke-dashoffset="' + offset + '" stroke-linecap="round" style="transition:stroke-dashoffset 1.5s ease-out;"/>' +
          '</svg>' +
          '<div class="qz-score-val">' +
            '<div class="qz-score-num" style="color:' + level.color + ';">' + score + '</div>' +
            '<div class="qz-score-label">de 100</div>' +
          '</div>' +
        '</div>' +
        '<span class="qz-level-badge" style="background:' + level.bg + ';border:1px solid ' + level.border + ';color:' + level.color + ';">' + level.emoji + ' ' + level.label + '</span>' +
      '</div>';

      html += '<p class="qz-level-desc">' + level.desc + '</p>';

      // Causes
      if (full || causes.length > 0) {
        html += '<h3 style="font-family:Sora,sans-serif;font-size:1rem;font-weight:700;color:#fff;margin:0 0 1rem;">';
        html += full ? '🔍 Causas identificadas no seu perfil:' : 'Principais pontos de atenção:';
        html += '</h3>';

        causes.forEach(function(item) {
          var c = causeData[item[0]];
          html += '<div class="qz-cause">' +
            '<div class="qz-cause-head"><span class="qz-cause-icon">' + c.icon + '</span><span class="qz-cause-name">' + c.name + '</span></div>';
          if (full) {
            html += '<p class="qz-cause-tip">' + c.tip + '</p>' +
              '<a href="' + c.link + '" class="qz-cause-link">Ler artigo completo →</a>';
          }
          html += '</div>';
        });
      }

      // Product CTA
      if (full) {
        var productTitle = score < 55 ? 'Seu sono precisa de suporte bioquímico' : 'Potencialize seus resultados';
        var productDesc = score < 55
          ? 'Com os padrões identificados, técnicas comportamentais sozinhas podem não ser suficientes. Melatonina + triptofano + magnésio + vitamina B6 atuam nas causas raiz.'
          : 'Seu sono tem boa base. Suplementação com magnésio e triptofano pode otimizar a qualidade dos ciclos de sono profundo.';

        var pills = [];
        causes.forEach(function(item) {
          var cat = item[0];
          if (cat === 'ansiedade' || cat === 'latencia') pills.push('Triptofano');
          if (cat === 'fragmentacao' || cat === 'ambiente') pills.push('Magnésio');
          if (cat === 'telas' || cat === 'cafeina') pills.push('Melatonina');
          if (cat === 'qualidade' || cat === 'exercicio') pills.push('Vitamina B6');
        });
        var uniquePills = pills.filter(function(v, i, a) { return a.indexOf(v) === i; });
        if (uniquePills.length === 0) uniquePills = ['Melatonina', 'Triptofano', 'Magnésio'];

        html += '<div class="qz-product">' +
          '<p style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#1DB8E8;margin:0 0 0.5rem;">Recomendação baseada no seu perfil</p>' +
          '<h3>' + productTitle + '</h3>' +
          '<p>' + productDesc + '</p>' +
          '<div class="qz-product-pills">';
        uniquePills.forEach(function(p) { html += '<span class="qz-pill">' + p + '</span>'; });
        html += '</div>' +
          '<a href="https://zencaps.com.br" target="_blank" rel="noopener" class="qz-cta qz-cta-gold" style="display:inline-block;width:auto;padding:14px 32px;text-decoration:none;font-size:0.95rem;">Conhecer Zen Caps →</a>' +
        '</div>';
      } else {
        html += '<div style="margin-top:2rem;padding:1.25rem;background:rgba(29,184,232,0.06);border:1px solid rgba(29,184,232,0.15);border-radius:14px;text-align:center;">' +
          '<p style="font-size:0.88rem;color:rgba(255,255,255,0.6);margin:0 0 0.75rem;">Quer o relatório completo com recomendações?</p>' +
          '<button type="button" class="qz-cta" onclick="qzShowScreen(\'scr-email\')" style="font-size:0.88rem;padding:12px 24px;">Desbloquear resultado completo</button>' +
        '</div>';
      }

      // Share & restart
      html += '<div style="display:flex;gap:12px;justify-content:center;margin-top:2rem;flex-wrap:wrap;">' +
        '<button type="button" onclick="qzReset()" style="background:none;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);padding:10px 20px;border-radius:10px;cursor:pointer;font-family:DM Sans,sans-serif;font-size:0.85rem;transition:all 0.2s;">Refazer quiz</button>' +
        '<a href="/blog/" style="display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);padding:10px 20px;border-radius:10px;text-decoration:none;font-size:0.85rem;transition:all 0.2s;">← Voltar ao blog</a>' +
      '</div>';

      document.getElementById('qz-result-content').innerHTML = html;
      qzShowScreen('scr-result');
    }

    function qzReset() {
      QZ.current = 0;
      QZ.answers = new Array(QZ.questions.length).fill(-1);
      QZ.hasEmail = false;
      document.getElementById('qz-progress').style.width = '0%';
      document.getElementById('qz-topbar').style.visibility = 'hidden';
      ['load-1','load-2','load-3'].forEach(function(id) { document.getElementById(id).classList.remove('done'); });
      qzShowScreen('scr-start');
    }
  </script>
</BlogLayout>
