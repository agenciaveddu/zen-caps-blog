---
import { getCollection, render } from 'astro:content'
import ArticleLayout from '../../layouts/ArticleLayout.astro'
import CTABanner from '../../components/CTABanner.astro'

export async function getStaticPaths() {
  const allPosts = await getCollection('blog')
  const now = new Date()
  // Apenas gera páginas para artigos já publicados
  const posts = allPosts.filter(post => post.data.publishedAt <= now)
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const categoryContext: Record<string, string> = {
  sono: 'insônia e dificuldade para dormir',
  ansiedade: 'ansiedade e estresse',
  ingredientes: 'dúvidas sobre suplementação',
  habitos: 'melhorar a qualidade do sono',
}
---

<ArticleLayout
  title={post.data.title}
  excerpt={post.data.excerpt}
  publishedAt={post.data.publishedAt}
  category={post.data.category}
  coverImage={post.data.coverImage}
  seoTitle={post.data.seoTitle}
  seoDescription={post.data.seoDescription}
  slug={post.id}
  quickAnswer={post.data.quickAnswer}
  readingTime={post.data.readingTime}
  faq={post.data.faq}
  author={post.data.author}
>
  <!-- Injeta o primeiro CTA após o início do conteúdo -->
  <CTABanner variant="inline" context={categoryContext[post.data.category]} />

  <!-- Conteúdo do artigo -->
  <Content />

  <!-- CTA no meio/fim do conteúdo -->
  <CTABanner variant="full" />
</ArticleLayout>
