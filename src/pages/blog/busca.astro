---
import BlogLayout from '../../layouts/BlogLayout.astro'

const categoryLabels: Record<string, string> = {
  sono: 'Sono & Insônia',
  ansiedade: 'Ansiedade & Estresse',
  ingredientes: 'Ingredientes & Ciência',
  habitos: 'Hábitos Saudáveis',
}

const categoryColors: Record<string, string> = {
  sono: '#1DB8E8',
  ansiedade: '#5B6FDE',
  ingredientes: '#1DB8E8',
  habitos: '#C9A84C',
}
---

<BlogLayout
  title="Buscar Artigos — Zen Caps Blog"
  description="Pesquise nos artigos do Zen Caps sobre sono, ansiedade, melatonina, magnésio e bem-estar natural."
  canonical="https://zencaps.com.br/blog/busca"
>
  <section style="background: #F4F8FC; min-height: 80vh; padding: 3rem 1rem 5rem;">
    <div class="max-w-3xl mx-auto">

      <!-- Header da página -->
      <div style="text-align: center; margin-bottom: 2.5rem;">
        <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #1DB8E8; margin-bottom: 10px; font-family: 'DM Sans', system-ui, sans-serif;">
          Buscar no blog
        </p>
        <h1 style="font-family: 'Sora', system-ui, sans-serif; font-size: clamp(1.8rem, 4vw, 2.4rem); font-weight: 800; color: #0D1B3E; margin-bottom: 0.5rem;">
          O que você quer aprender?
        </h1>
        <p style="color: #6B7A9A; font-size: 1rem; font-family: 'DM Sans', system-ui, sans-serif;">
          Pesquise sobre sono, ansiedade, melatonina, magnésio e muito mais.
        </p>
      </div>

      <!-- Campo de busca -->
      <div style="position: relative; margin-bottom: 2rem;">
        <div style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #6B7A9A; pointer-events: none;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <input
          id="search-input"
          type="search"
          placeholder="Ex: melatonina, insônia, respiração..."
          autocomplete="off"
          style="
            width: 100%;
            padding: 1rem 1.25rem 1rem 52px;
            font-size: 1.05rem;
            font-family: 'DM Sans', system-ui, sans-serif;
            border: 2px solid #e8eef6;
            border-radius: 16px;
            background: #ffffff;
            color: #0D1B3E;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            box-shadow: 0 2px 12px rgba(13,27,62,0.06);
            box-sizing: border-box;
          "
        />
        <button
          id="clear-btn"
          style="display: none; position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #6B7A9A; padding: 4px;"
          aria-label="Limpar busca"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Status / contagem -->
      <div id="search-status" style="font-size: 0.85rem; color: #6B7A9A; margin-bottom: 1.25rem; font-family: 'DM Sans', system-ui, sans-serif; min-height: 22px;">
      </div>

      <!-- Resultados -->
      <div id="results-container">

        <!-- Estado inicial: artigos recentes -->
        <div id="initial-state">
          <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #6B7A9A; margin-bottom: 1rem; font-family: 'DM Sans', system-ui, sans-serif;">
            Artigos recentes
          </p>
          <div id="recent-articles" style="display: flex; flex-direction: column; gap: 12px;"></div>
        </div>

        <!-- Estado de busca: resultados -->
        <div id="search-results" style="display: none; flex-direction: column; gap: 12px;"></div>

        <!-- Sem resultados -->
        <div id="no-results" style="display: none; text-align: center; padding: 4rem 1rem;">
          <p style="font-size: 3rem; margin-bottom: 1rem;">🔍</p>
          <p style="font-family: 'Sora', system-ui, sans-serif; font-size: 1.1rem; font-weight: 700; color: #0D1B3E; margin-bottom: 0.5rem;">Nenhum artigo encontrado</p>
          <p style="color: #6B7A9A; font-size: 0.9rem; font-family: 'DM Sans', system-ui, sans-serif;">Tente termos como "melatonina", "insônia" ou "ansiedade"</p>
        </div>

      </div>
    </div>
  </section>
</BlogLayout>

<style>
  #search-input:focus {
    border-color: #1DB8E8;
    box-shadow: 0 0 0 3px rgba(29,184,232,0.12), 0 2px 12px rgba(13,27,62,0.06);
  }
  #search-input::placeholder {
    color: #a0aec0;
  }

  .result-card {
    display: flex;
    gap: 16px;
    background: #ffffff;
    border: 1px solid #e8eef6;
    border-radius: 14px;
    padding: 16px;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    align-items: flex-start;
  }
  .result-card:hover {
    border-color: #1DB8E8;
    box-shadow: 0 4px 20px rgba(29,184,232,0.1);
    transform: translateY(-1px);
  }
  .result-thumb {
    width: 80px;
    height: 80px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
    background: #0D1B3E;
  }
  .result-thumb-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 10px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #0D1B3E, #172851);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }
  .result-body {
    flex: 1;
    min-width: 0;
  }
  .result-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 10px;
    border-radius: 999px;
    margin-bottom: 6px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .result-title {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #0D1B3E;
    margin: 0 0 5px;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .result-excerpt {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.83rem;
    color: #6B7A9A;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  mark {
    background: rgba(29,184,232,0.18);
    color: #0D1B3E;
    border-radius: 3px;
    padding: 0 2px;
  }
</style>

<script>
  // Category metadata
  const catLabels: Record<string, string> = {
    sono: 'Sono & Insônia',
    ansiedade: 'Ansiedade & Estresse',
    ingredientes: 'Ingredientes & Ciência',
    habitos: 'Hábitos Saudáveis',
  }
  const catColors: Record<string, string> = {
    sono: '#1DB8E8',
    ansiedade: '#5B6FDE',
    ingredientes: '#1DB8E8',
    habitos: '#C9A84C',
  }
  const catIcons: Record<string, string> = {
    sono: '🌙',
    ansiedade: '🧘',
    ingredientes: '🔬',
    habitos: '✨',
  }

  type Article = {
    slug: string
    title: string
    excerpt: string
    category: string
    coverImage: string | null
    publishedAt: string
    quickAnswer: string
    seoDescription: string
  }

  let allArticles: Article[] = []
  let fuse: any = null

  // Build a card HTML string
  function buildCard(article: Article, highlight?: string): string {
    const label = catLabels[article.category] ?? article.category
    const color = catColors[article.category] ?? '#1DB8E8'
    const icon = catIcons[article.category] ?? '📄'

    const thumb = article.coverImage
      ? `<img class="result-thumb" src="${article.coverImage}" alt="${article.title}" loading="lazy" />`
      : `<div class="result-thumb-placeholder">${icon}</div>`

    let title = article.title
    let excerpt = article.excerpt

    // Highlight matching terms
    if (highlight) {
      const terms = highlight.trim().split(/\s+/).filter(Boolean)
      terms.forEach(term => {
        const re = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi')
        title = title.replace(re, '<mark>$1</mark>')
        excerpt = excerpt.replace(re, '<mark>$1</mark>')
      })
    }

    return `
      <a href="/blog/${article.slug}" class="result-card">
        ${thumb}
        <div class="result-body">
          <span class="result-badge" style="background: ${color}18; color: ${color};">${label}</span>
          <p class="result-title">${title}</p>
          <p class="result-excerpt">${excerpt}</p>
        </div>
      </a>
    `
  }

  async function init() {
    // Load article index
    const res = await fetch('/blog/search.json')
    allArticles = await res.json()

    // Load Fuse.js from CDN
    await new Promise<void>((resolve, reject) => {
      const s = document.createElement('script')
      s.src = 'https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js'
      s.onload = () => resolve()
      s.onerror = reject
      document.head.appendChild(s)
    })

    // Init Fuse
    fuse = new (window as any).Fuse(allArticles, {
      keys: [
        { name: 'title',          weight: 0.5 },
        { name: 'excerpt',        weight: 0.25 },
        { name: 'quickAnswer',    weight: 0.15 },
        { name: 'seoDescription', weight: 0.1 },
      ],
      threshold: 0.4,
      includeScore: true,
      minMatchCharLength: 2,
    })

    // Render recent articles (initial state)
    const recentEl = document.getElementById('recent-articles')!
    recentEl.innerHTML = allArticles
      .slice(0, 5)
      .map(a => buildCard(a))
      .join('')

    // Check URL param
    const params = new URLSearchParams(window.location.search)
    const q = params.get('q')
    if (q) {
      const input = document.getElementById('search-input') as HTMLInputElement
      input.value = q
      performSearch(q)
    }

    setupListeners()
  }

  function performSearch(query: string) {
    const initialEl  = document.getElementById('initial-state')!
    const resultsEl  = document.getElementById('search-results')!
    const noResultEl = document.getElementById('no-results')!
    const statusEl   = document.getElementById('search-status')!
    const clearBtn   = document.getElementById('clear-btn')!

    if (!query.trim()) {
      initialEl.style.display  = 'block'
      resultsEl.style.display  = 'none'
      noResultEl.style.display = 'none'
      statusEl.textContent     = ''
      clearBtn.style.display   = 'none'
      // Update URL
      history.replaceState({}, '', '/blog/busca')
      return
    }

    clearBtn.style.display = 'block'

    const results = fuse.search(query).slice(0, 12)

    // Update URL
    history.replaceState({}, '', `/blog/busca?q=${encodeURIComponent(query)}`)

    if (results.length === 0) {
      initialEl.style.display  = 'none'
      resultsEl.style.display  = 'none'
      noResultEl.style.display = 'block'
      statusEl.textContent     = ''
      return
    }

    statusEl.textContent = `${results.length} artigo${results.length !== 1 ? 's' : ''} encontrado${results.length !== 1 ? 's' : ''}`

    resultsEl.innerHTML = results
      .map((r: any) => buildCard(r.item, query))
      .join('')

    initialEl.style.display  = 'none'
    resultsEl.style.display  = 'flex'
    noResultEl.style.display = 'none'
  }

  function setupListeners() {
    const input    = document.getElementById('search-input') as HTMLInputElement
    const clearBtn = document.getElementById('clear-btn')!

    let debounceTimer: ReturnType<typeof setTimeout>

    input.addEventListener('input', () => {
      clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => performSearch(input.value), 200)
    })

    input.addEventListener('focus', () => {
      input.style.borderColor = '#1DB8E8'
    })
    input.addEventListener('blur', () => {
      if (!input.value) input.style.borderColor = '#e8eef6'
    })

    clearBtn.addEventListener('click', () => {
      input.value = ''
      input.focus()
      performSearch('')
    })
  }

  init()
</script>
