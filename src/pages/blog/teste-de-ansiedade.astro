---
import BlogLayout from '../../layouts/BlogLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Teste de Ansiedade — Zen Caps',
  description: 'Avalie seu nível de ansiedade com este teste gratuito baseado na escala GAD-7. Descubra se sua ansiedade é leve, moderada ou severa e veja recomendações.',
  url: 'https://zencaps.com.br/blog/teste-de-ansiedade/',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'BRL' },
  author: { '@type': 'Organization', name: 'Zen Caps', url: 'https://zencaps.com.br' },
}
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://zencaps.com.br/blog/' },
    { '@type': 'ListItem', position: 2, name: 'Teste de Ansiedade', item: 'https://zencaps.com.br/blog/teste-de-ansiedade/' },
  ],
}
---

<BlogLayout
  title="Teste de Ansiedade Gratuito — Avalie Seu Nível | Zen Caps"
  description="Teste gratuito baseado na escala GAD-7 para avaliar seu nível de ansiedade. Descubra se é leve, moderada ou severa e veja recomendações baseadas em ciência."
  canonical="https://zencaps.com.br/blog/teste-de-ansiedade/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <style>
    .quiz-option{display:flex;align-items:center;gap:12px;padding:14px 18px;border:2px solid #e8eef6;border-radius:12px;cursor:pointer;transition:all .2s;background:#fff;font-family:'DM Sans',system-ui,sans-serif;font-size:.92rem;color:#3A4A6B;width:100%;text-align:left}
    .quiz-option:hover{border-color:#1DB8E8;background:#f0f9ff}
    .quiz-option.selected{border-color:#1DB8E8;background:#e8f7fc;color:#0D1B3E;font-weight:600}
    .quiz-option .opt-letter{width:32px;height:32px;border-radius:8px;background:#F4F8FC;display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-weight:700;font-size:.8rem;color:#6B7A9A;flex-shrink:0;transition:all .2s}
    .quiz-option.selected .opt-letter{background:#1DB8E8;color:#fff}
    .quiz-progress-bar{height:6px;background:#e8eef6;border-radius:3px;overflow:hidden}
    .quiz-progress-fill{height:100%;background:linear-gradient(90deg,#1DB8E8,#5DD4F4);border-radius:3px;transition:width .4s ease}
    .quiz-btn{padding:.85rem 2rem;border:none;border-radius:12px;font-family:'Sora',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;transition:all .2s}
    .quiz-btn-primary{background:linear-gradient(135deg,#1DB8E8,#5DD4F4);color:#fff;box-shadow:0 4px 16px rgba(29,184,232,.3)}
    .quiz-btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(29,184,232,.4)}
    .quiz-btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
    .quiz-btn-secondary{background:transparent;color:#6B7A9A;border:1px solid #e8eef6}
    .quiz-btn-secondary:hover{border-color:#1DB8E8;color:#1DB8E8}
    .score-bar-bg{height:12px;background:#e8eef6;border-radius:6px;overflow:hidden;position:relative}
    .score-bar-fill{height:100%;border-radius:6px;transition:width 1s ease}
    .email-input{width:100%;padding:14px 18px;border:2px solid #e8eef6;border-radius:12px;font-family:'DM Sans',sans-serif;font-size:.95rem;color:#0D1B3E;outline:none;transition:border-color .2s;background:#F4F8FC}
    .email-input:focus{border-color:#1DB8E8}
    .fade-in{animation:fadeIn .4s ease}
    @keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
  </style>

  <div style="background: #F4F8FC; min-height: 80vh;">

    <section style="background: linear-gradient(135deg, #0D1B3E 0%, #172851 100%); padding: 4rem 1.5rem 3.5rem;">
      <div style="max-width: 720px; margin: 0 auto; text-align: center;">
        <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: #1DB8E8; margin-bottom: 0.75rem;">Avaliação gratuita — 1 minuto</p>
        <h1 style="font-family: 'Sora', system-ui, sans-serif; font-size: clamp(1.8rem, 5vw, 2.6rem); font-weight: 900; color: #ffffff; line-height: 1.15; margin-bottom: 1rem;">
          Teste de Ansiedade
        </h1>
        <p style="font-size: 1.05rem; color: rgba(255,255,255,0.65); line-height: 1.7; max-width: 500px; margin: 0 auto;">
          Avalie seu nível de ansiedade com base na escala GAD-7, validada cientificamente.
        </p>
      </div>
    </section>

    <section style="padding: 0 1.5rem; margin-top: -1.5rem;">
      <div style="max-width: 600px; margin: 0 auto;">
        <div id="quiz-card" style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 4px 24px rgba(13,27,62,0.08); padding: 2rem; border: 1px solid #e8eef6; min-height: 400px;">

          <div id="screen-start">
            <div style="text-align: center; padding: 1rem 0;">
              <div style="font-size: 3rem; margin-bottom: 1rem;">🧘</div>
              <h2 style="font-family: 'Sora', sans-serif; font-size: 1.3rem; font-weight: 800; color: #0D1B3E; margin: 0 0 0.75rem;">Avalie sua ansiedade</h2>
              <p style="font-size: 0.92rem; color: #6B7A9A; line-height: 1.7; margin: 0 0 0.5rem;">Baseado na escala GAD-7 — usada por profissionais de saúde no mundo inteiro.</p>
              <p style="font-size: 0.82rem; color: #9ba8c4; margin: 0 0 1.5rem;">7 perguntas — 1 minuto</p>

              <div style="background: #FFF8E7; border: 1px solid #F5D170; border-radius: 12px; padding: 14px; margin-bottom: 2rem; text-align: left;">
                <p style="font-size: 0.82rem; color: #7A5900; line-height: 1.55; margin: 0;">
                  <strong>Aviso:</strong> Este teste é informativo e educacional. Não substitui avaliação profissional. Se você sente que sua ansiedade está prejudicando sua vida, procure um psicólogo ou psiquiatra.
                </p>
              </div>

              <p style="font-size: 0.88rem; color: #3A4A6B; margin: 0 0 1.5rem; line-height: 1.6;">Para cada pergunta, considere como você se sentiu nas <strong>últimas 2 semanas</strong>.</p>
              <button type="button" class="quiz-btn quiz-btn-primary" onclick="startQuiz()" style="width: 100%;">Iniciar avaliação</button>
            </div>
          </div>

          <div id="screen-question" style="display: none;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
              <span id="q-counter" style="font-family: 'Sora', sans-serif; font-size: 0.75rem; font-weight: 700; color: #1DB8E8;"></span>
              <span id="q-percent" style="font-size: 0.75rem; color: #9ba8c4;"></span>
            </div>
            <div class="quiz-progress-bar" style="margin-bottom: 1.5rem;"><div id="progress-fill" class="quiz-progress-fill" style="width: 0%;"></div></div>
            <p style="font-size: 0.78rem; color: #9ba8c4; margin: 0 0 6px;">Nas últimas 2 semanas, com que frequência você foi incomodado por:</p>
            <h3 id="q-title" style="font-family: 'Sora', sans-serif; font-size: 1.05rem; font-weight: 700; color: #0D1B3E; margin: 0 0 1.25rem; line-height: 1.4;"></h3>
            <div id="q-options" style="display: flex; flex-direction: column; gap: 10px;"></div>
            <div style="display: flex; justify-content: space-between; margin-top: 1.5rem;">
              <button type="button" id="btn-prev" class="quiz-btn quiz-btn-secondary" onclick="prevQuestion()" style="display: none;">← Voltar</button>
              <button type="button" id="btn-next" class="quiz-btn quiz-btn-primary" onclick="nextQuestion()" disabled style="margin-left: auto;">Próxima →</button>
            </div>
          </div>

          <div id="screen-email" style="display: none;" class="fade-in">
            <div style="text-align: center; padding: 1rem 0;">
              <div id="score-preview" style="margin-bottom: 1.5rem;"></div>
              <h2 style="font-family: 'Sora', sans-serif; font-size: 1.2rem; font-weight: 800; color: #0D1B3E; margin: 0 0 0.5rem;">Sua avaliação está pronta!</h2>
              <p style="font-size: 0.88rem; color: #6B7A9A; line-height: 1.6; margin: 0 0 1.5rem;">
                Informe seu email para receber o <strong>relatório completo</strong> com análise detalhada e recomendações baseadas em evidências.
              </p>
              <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 1rem;">
                <input type="text" id="lead-name" class="email-input" placeholder="Seu nome" />
                <input type="email" id="lead-email" class="email-input" placeholder="Seu melhor email" />
              </div>
              <button type="button" class="quiz-btn quiz-btn-primary" onclick="submitEmail()" style="width: 100%;">Ver meu relatório completo</button>
              <button type="button" style="background:none;border:none;color:#9ba8c4;font-size:.78rem;cursor:pointer;margin-top:12px;font-family:'DM Sans',sans-serif;" onclick="skipEmail()">Pular e ver resultado resumido</button>
              <p style="font-size: 0.7rem; color: #b8c4d9; margin: 12px 0 0; line-height: 1.5;">Seus dados estão seguros. Sem spam. Cancele quando quiser.</p>
            </div>
          </div>

          <div id="screen-result" style="display: none;" class="fade-in">
            <div id="result-content"></div>
          </div>
        </div>
      </div>
    </section>

    <section style="padding: 3rem 1.5rem 0;">
      <div style="max-width: 680px; margin: 0 auto;">
        <div style="background: #FFFFFF; border-radius: 18px; padding: 2rem; border: 1px solid #e8eef6; margin-bottom: 2rem;">
          <h2 style="font-family: 'Sora', sans-serif; font-size: 1.3rem; font-weight: 800; color: #0D1B3E; margin: 0 0 1rem;">Sobre a escala GAD-7</h2>
          <p style="font-size: 0.95rem; color: #3A4A6B; line-height: 1.8; margin: 0 0 1rem;">
            O GAD-7 (Generalized Anxiety Disorder 7-item scale) é uma das escalas mais utilizadas mundialmente para rastreamento de ansiedade. Foi desenvolvida por Spitzer, Kroenke e Williams em 2006 e é validada em português brasileiro.
          </p>
          <p style="font-size: 0.95rem; color: #3A4A6B; line-height: 1.8; margin: 0;">
            A escala avalia a frequência de 7 sintomas nas últimas 2 semanas, gerando um score de 0 a 21. Não é um diagnóstico — é uma ferramenta de rastreamento que indica quando buscar ajuda profissional.
          </p>
        </div>
        <div style="background: #FFFFFF; border-radius: 18px; padding: 2rem; border: 1px solid #e8eef6; margin-bottom: 2rem;">
          <h3 style="font-family: 'Sora', sans-serif; font-size: 1.1rem; font-weight: 700; color: #0D1B3E; margin: 0 0 1rem;">Artigos relacionados</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
            <li><a href="/blog/como-controlar-ansiedade-naturalmente/" style="color: #1DB8E8; text-decoration: none; font-weight: 600; font-size: 0.92rem;">Como controlar ansiedade naturalmente</a></li>
            <li><a href="/blog/ansiedade-noite-por-que-piora-ao-deitar/" style="color: #1DB8E8; text-decoration: none; font-weight: 600; font-size: 0.92rem;">Por que a ansiedade piora à noite</a></li>
            <li><a href="/blog/crise-de-ansiedade-agora-protocolo-5-minutos/" style="color: #1DB8E8; text-decoration: none; font-weight: 600; font-size: 0.92rem;">Crise de ansiedade: protocolo de 5 minutos</a></li>
            <li><a href="/blog/respiracao-para-ansiedade-tecnicas/" style="color: #1DB8E8; text-decoration: none; font-weight: 600; font-size: 0.92rem;">Técnicas de respiração para ansiedade</a></li>
          </ul>
        </div>
        <div style="text-align: center; padding-bottom: 4rem;">
          <a href="/blog/" style="display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 700; color: #1DB8E8; text-decoration: none; font-size: 0.95rem;">&larr; Voltar para o blog</a>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const questions = [
      { q: 'Sentir-se nervoso(a), ansioso(a) ou muito tenso(a)' },
      { q: 'Não ser capaz de impedir ou de controlar as preocupações' },
      { q: 'Preocupar-se muito com diversas coisas' },
      { q: 'Dificuldade para relaxar' },
      { q: 'Ficar tão inquieto(a) que é difícil ficar sentado(a) quieto(a)' },
      { q: 'Ficar facilmente irritado(a) ou aborrecido(a)' },
      { q: 'Sentir medo como se algo horrível fosse acontecer' },
    ];

    const scaleOpts = [
      { text: 'Nenhuma vez', score: 0 },
      { text: 'Vários dias', score: 1 },
      { text: 'Mais da metade dos dias', score: 2 },
      { text: 'Quase todos os dias', score: 3 },
    ];

    let currentQ = 0;
    let answers = new Array(questions.length).fill(-1);
    const letters = ['A','B','C','D'];

    function showScreen(id) {
      ['screen-start','screen-question','screen-email','screen-result'].forEach(s => {
        document.getElementById(s).style.display = s === id ? 'block' : 'none';
      });
    }
    function startQuiz() { showScreen('screen-question'); renderQuestion(); }

    function renderQuestion() {
      document.getElementById('q-counter').textContent = `PERGUNTA ${currentQ+1} DE ${questions.length}`;
      const pct = Math.round((currentQ / questions.length) * 100);
      document.getElementById('q-percent').textContent = pct + '%';
      document.getElementById('progress-fill').style.width = pct + '%';
      document.getElementById('q-title').textContent = questions[currentQ].q;
      const optsEl = document.getElementById('q-options');
      optsEl.innerHTML = '';
      scaleOpts.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'quiz-option' + (answers[currentQ] === i ? ' selected' : '');
        btn.innerHTML = `<span class="opt-letter">${letters[i]}</span><span>${opt.text}</span>`;
        btn.addEventListener('click', () => selectOption(i));
        optsEl.appendChild(btn);
      });
      document.getElementById('btn-prev').style.display = currentQ > 0 ? 'inline-flex' : 'none';
      document.getElementById('btn-next').disabled = answers[currentQ] === -1;
      document.getElementById('btn-next').textContent = currentQ === questions.length - 1 ? 'Ver resultado' : 'Próxima →';
    }

    function selectOption(i) {
      answers[currentQ] = i;
      document.querySelectorAll('.quiz-option').forEach((el, idx) => el.classList.toggle('selected', idx === i));
      document.getElementById('btn-next').disabled = false;
    }
    function nextQuestion() { if (currentQ < questions.length - 1) { currentQ++; renderQuestion(); } else { showEmailGate(); } }
    function prevQuestion() { if (currentQ > 0) { currentQ--; renderQuestion(); } }

    function calcScore() { return answers.reduce((sum, a) => sum + scaleOpts[a].score, 0); }

    function getLevel(score) {
      if (score <= 4) return { label: 'Ansiedade Mínima', color: '#0fa36b', bg: '#f0fdf4', border: '#bbf7d0', emoji: '🟢', pct: Math.round((score/21)*100),
        desc: 'Seus níveis de ansiedade estão dentro do normal. Continue mantendo seus hábitos saudáveis.',
        rec: 'Mantenha suas rotinas de sono, exercício e alimentação. Práticas de mindfulness podem fortalecer ainda mais sua saúde mental.' };
      if (score <= 9) return { label: 'Ansiedade Leve', color: '#C9A84C', bg: '#fffbeb', border: '#fde68a', emoji: '🟡', pct: Math.round((score/21)*100),
        desc: 'Você apresenta sintomas leves de ansiedade. É comum e geralmente manejável com mudanças de hábitos.',
        rec: 'Técnicas de respiração, exercício regular e suporte nutricional (magnésio + triptofano) podem reduzir significativamente esses sintomas.' };
      if (score <= 14) return { label: 'Ansiedade Moderada', color: '#e67e22', bg: '#fff7ed', border: '#fed7aa', emoji: '🟠', pct: Math.round((score/21)*100),
        desc: 'Seus sintomas indicam ansiedade moderada. Este nível já pode impactar sua qualidade de vida e sono.',
        rec: 'Considere consultar um profissional de saúde mental. Enquanto isso, técnicas de relaxamento e suplementação natural podem ajudar a reduzir os sintomas.' };
      return { label: 'Ansiedade Severa', color: '#e74c3c', bg: '#fef2f2', border: '#fecaca', emoji: '🔴', pct: Math.round((score/21)*100),
        desc: 'Seus sintomas indicam ansiedade severa. É importante buscar ajuda profissional.',
        rec: 'Recomendamos fortemente que você consulte um psicólogo ou psiquiatra. A ansiedade neste nível pode ser tratada eficazmente com acompanhamento adequado.' };
    }

    function showEmailGate() {
      const score = calcScore(), level = getLevel(score);
      document.getElementById('score-preview').innerHTML = `
        <div style="text-align:center;">
          <div style="font-family:'Sora',sans-serif;font-size:2.5rem;font-weight:900;color:${level.color};margin-bottom:4px;">${score}<span style="font-size:1.2rem;color:#6B7A9A;">/21</span></div>
          <span style="display:inline-block;padding:4px 14px;border-radius:20px;background:${level.bg};border:1px solid ${level.border};font-family:'Sora',sans-serif;font-weight:700;font-size:.82rem;color:${level.color};">${level.emoji} ${level.label}</span>
        </div>`;
      showScreen('screen-email');
    }

    function submitEmail() {
      const name = document.getElementById('lead-name').value.trim();
      const email = document.getElementById('lead-email').value.trim();
      if (!email || !email.includes('@')) { document.getElementById('lead-email').style.borderColor = '#e74c3c'; return; }
      saveLead({ name, email, quiz: 'ansiedade', score: calcScore(), answers: answers });
      showResult(true);
    }
    function skipEmail() { showResult(false); }

    function saveLead(data) {
      try { const leads = JSON.parse(localStorage.getItem('zc_leads')||'[]'); leads.push({...data,ts:new Date().toISOString()}); localStorage.setItem('zc_leads',JSON.stringify(leads)); } catch(e){}
    }

    function showResult(full) {
      const score = calcScore(), level = getLevel(score);
      const barWidth = Math.max(5, level.pct);

      let html = `
        <div style="text-align:center;margin-bottom:1.5rem;">
          <div style="font-family:'Sora',sans-serif;font-size:3rem;font-weight:900;color:${level.color};margin-bottom:4px;">${score}<span style="font-size:1.5rem;color:#6B7A9A;">/21</span></div>
          <span style="display:inline-block;padding:6px 16px;border-radius:20px;background:${level.bg};border:1px solid ${level.border};font-family:'Sora',sans-serif;font-weight:700;font-size:.9rem;color:${level.color};">${level.emoji} ${level.label}</span>
        </div>

        <div style="margin-bottom:1.5rem;">
          <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
            <span style="font-size:.72rem;color:#0fa36b;font-weight:600;">Mínima</span>
            <span style="font-size:.72rem;color:#C9A84C;font-weight:600;">Leve</span>
            <span style="font-size:.72rem;color:#e67e22;font-weight:600;">Moderada</span>
            <span style="font-size:.72rem;color:#e74c3c;font-weight:600;">Severa</span>
          </div>
          <div style="position:relative;height:12px;background:linear-gradient(90deg,#bbf7d0 0%,#fde68a 33%,#fed7aa 66%,#fecaca 100%);border-radius:6px;">
            <div style="position:absolute;left:${barWidth}%;top:-2px;width:16px;height:16px;background:${level.color};border-radius:50%;border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.2);transform:translateX(-50%);transition:left 1s ease;"></div>
          </div>
          <div style="display:flex;justify-content:space-between;margin-top:4px;">
            <span style="font-size:.65rem;color:#9ba8c4;">0</span>
            <span style="font-size:.65rem;color:#9ba8c4;">5</span>
            <span style="font-size:.65rem;color:#9ba8c4;">10</span>
            <span style="font-size:.65rem;color:#9ba8c4;">15</span>
            <span style="font-size:.65rem;color:#9ba8c4;">21</span>
          </div>
        </div>

        <p style="font-size:.92rem;color:#3A4A6B;line-height:1.7;margin:0 0 1.5rem;text-align:center;">${level.desc}</p>
      `;

      if (full) {
        html += `
          <div style="padding:1.25rem;background:#F4F8FC;border-radius:12px;margin-bottom:1.25rem;border-left:4px solid ${level.color};">
            <h4 style="font-family:'Sora',sans-serif;font-size:.95rem;font-weight:700;color:#0D1B3E;margin:0 0 .5rem;">Recomendações para seu nível</h4>
            <p style="font-size:.88rem;color:#3A4A6B;line-height:1.7;margin:0;">${level.rec}</p>
          </div>
        `;

        if (score >= 5) {
          html += `
            <div style="padding:1.25rem;background:#F4F8FC;border-radius:12px;margin-bottom:1.25rem;">
              <h4 style="font-family:'Sora',sans-serif;font-size:.95rem;font-weight:700;color:#0D1B3E;margin:0 0 .75rem;">O que pode ajudar:</h4>
              <ul style="font-size:.88rem;color:#3A4A6B;line-height:1.8;padding-left:1.25rem;margin:0;">
                <li><strong>Respiração 4-7-8</strong> — ativa o nervo vago e reduz cortisol em minutos</li>
                <li><strong>Exercício regular</strong> — tão eficaz quanto medicação para ansiedade leve-moderada</li>
                <li><strong>Higiene do sono</strong> — sono ruim piora ansiedade em até 30%</li>
                <li><strong>Magnésio + Triptofano</strong> — suporte bioquímico para o sistema GABA e serotonina</li>
                ${score >= 10 ? '<li><strong>Acompanhamento profissional</strong> — psicoterapia (TCC) é o tratamento mais eficaz</li>' : ''}
              </ul>
            </div>
          `;
        }

        html += `
          <div style="margin-top:1.5rem;padding:1.5rem;background:linear-gradient(135deg,#0D1B3E,#172851);border-radius:14px;text-align:center;">
            <p style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#1DB8E8;margin:0 0 .5rem;">Suporte natural para ansiedade</p>
            <h4 style="font-family:'Sora',sans-serif;font-size:1.05rem;font-weight:800;color:#fff;margin:0 0 .75rem;line-height:1.3;">
              ${score >= 10 ? 'Cuide da bioquímica enquanto busca ajuda profissional' : 'Reforce seu equilíbrio emocional naturalmente'}
            </h4>
            <p style="font-size:.85rem;color:rgba(255,255,255,.6);line-height:1.6;margin:0 0 1rem;">
              Magnésio ativa o GABA (o calmante natural do cérebro). Triptofano é precursor da serotonina. Juntos, ajudam a reduzir ansiedade e melhorar o sono — sem dependência.
            </p>
