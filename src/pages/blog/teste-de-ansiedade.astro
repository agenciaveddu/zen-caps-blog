---
import BlogLayout from '../../layouts/BlogLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Teste de Ansiedade — Zen Caps',
  description: 'Avalie seu nível de ansiedade com este teste gratuito baseado na escala GAD-7. Descubra se sua ansiedade é leve, moderada ou severa e veja recomendações.',
  url: 'https://zencaps.com.br/blog/teste-de-ansiedade/',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'BRL' },
  author: { '@type': 'Organization', name: 'Zen Caps', url: 'https://zencaps.com.br' },
}
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://zencaps.com.br/blog/' },
    { '@type': 'ListItem', position: 2, name: 'Teste de Ansiedade', item: 'https://zencaps.com.br/blog/teste-de-ansiedade/' },
  ],
}
---

<BlogLayout
  title="Teste de Ansiedade Gratuito (GAD-7) — Avalie Seu Nível | Zen Caps"
  description="Teste gratuito baseado na escala GAD-7 para avaliar seu nível de ansiedade. Descubra se é leve, moderada ou severa e veja recomendações baseadas em ciência."
  canonical="https://zencaps.com.br/blog/teste-de-ansiedade/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <style is:inline>
    /* ===== ANXIETY TEST GLOBAL STYLES ===== */
    .ax-wrap { background: linear-gradient(180deg, #0a1628 0%, #0D1B3E 50%, #111d3a 100%); min-height: 100vh; font-family: 'DM Sans', system-ui, sans-serif; overflow-x: hidden; }
    .ax-container { max-width: 540px; margin: 0 auto; padding: 0 1.25rem; }

    /* Progress bar */
    .ax-progress { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 4px; background: rgba(255,255,255,0.08); }
    .ax-progress-fill { height: 100%; background: linear-gradient(90deg, #1DB8E8, #5DD4F4); border-radius: 0 2px 2px 0; transition: width 0.6s cubic-bezier(0.4,0,0.2,1); }

    /* Top bar */
    .ax-topbar { display: flex; align-items: center; justify-content: space-between; padding: 1rem 0 0.5rem; }
    .ax-topbar-back { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 8px; border-radius: 8px; transition: all 0.2s; display: flex; align-items: center; }
    .ax-topbar-back:hover { color: #fff; background: rgba(255,255,255,0.08); }
    .ax-topbar-step { font-family: 'Sora', sans-serif; font-size: 0.72rem; font-weight: 700; color: rgba(255,255,255,0.35); letter-spacing: 0.1em; text-transform: uppercase; }

    /* Screens */
    .ax-screen { display: none; }
    .ax-screen.active { display: block; animation: axSlideIn 0.4s cubic-bezier(0.4,0,0.2,1); }
    @keyframes axSlideIn { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
    @keyframes axFadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes axPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    @keyframes axSpin { to { transform: rotate(360deg); } }
    @keyframes axCountUp { from { opacity: 0; transform: scale(0.5); } to { opacity: 1; transform: scale(1); } }
    @keyframes axBreath { 0%, 100% { transform: scale(1); opacity: 0.6; } 50% { transform: scale(1.15); opacity: 1; } }

    /* Question */
    .ax-question-label { font-size: 0.72rem; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.1em; margin: 1.5rem 0 0.5rem; }
    .ax-question { font-family: 'Sora', sans-serif; font-size: 1.25rem; font-weight: 800; color: #ffffff; line-height: 1.35; margin: 0 0 1.75rem; }

    /* Option cards */
    .ax-option {
      display: flex; align-items: center; gap: 14px; width: 100%;
      padding: 16px 20px; margin-bottom: 10px;
      background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.08);
      border-radius: 14px; cursor: pointer; transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
      color: rgba(255,255,255,0.8); font-size: 0.95rem; text-align: left;
      font-family: 'DM Sans', system-ui, sans-serif;
    }
    .ax-option:hover { background: rgba(29,184,232,0.08); border-color: rgba(29,184,232,0.3); transform: translateX(4px); }
    .ax-option.selected { background: rgba(29,184,232,0.12); border-color: #1DB8E8; color: #fff; transform: scale(1.02); }
    .ax-option .ax-opt-icon {
      width: 40px; height: 40px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.25rem; flex-shrink: 0;
      background: rgba(255,255,255,0.06); transition: all 0.25s;
    }
    .ax-option.selected .ax-opt-icon { background: #1DB8E8; }
    .ax-option .ax-opt-text { font-weight: 500; line-height: 1.4; }
    .ax-option.selected .ax-opt-text { font-weight: 700; }
    .ax-option .ax-opt-check { margin-left: auto; opacity: 0; transition: opacity 0.2s; flex-shrink: 0; }
    .ax-option.selected .ax-opt-check { opacity: 1; }

    /* Start screen */
    .ax-hero { text-align: center; padding: 3rem 0 2rem; }
    .ax-hero-icon { font-size: 4rem; margin-bottom: 1rem; animation: axBreath 4s ease-in-out infinite; display: inline-block; }
    .ax-hero h1 { font-family: 'Sora', sans-serif; font-size: clamp(1.6rem, 5vw, 2.2rem); font-weight: 900; color: #fff; line-height: 1.15; margin: 0 0 0.75rem; }
    .ax-hero h1 span { color: #1DB8E8; }
    .ax-hero p { font-size: 1rem; color: rgba(255,255,255,0.5); line-height: 1.7; margin: 0 0 2rem; max-width: 400px; margin-left: auto; margin-right: auto; }
    .ax-features { display: flex; flex-direction: column; gap: 12px; margin-bottom: 2rem; text-align: left; max-width: 340px; margin-left: auto; margin-right: auto; }
    .ax-feature { display: flex; align-items: center; gap: 12px; padding: 10px 16px; background: rgba(29,184,232,0.06); border: 1px solid rgba(29,184,232,0.12); border-radius: 12px; }
    .ax-feature-icon { font-size: 1.2rem; }
    .ax-feature-text { font-size: 0.88rem; color: rgba(255,255,255,0.7); }
    .ax-feature-text strong { color: #fff; }

    /* Clinical badge */
    .ax-clinical { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: rgba(29,184,232,0.08); border: 1px solid rgba(29,184,232,0.15); border-radius: 20px; margin-bottom: 1.5rem; }
    .ax-clinical-icon { font-size: 1rem; }
    .ax-clinical-text { font-size: 0.75rem; font-weight: 600; color: #1DB8E8; letter-spacing: 0.05em; }

    /* CTA button */
    .ax-cta {
      width: 100%; padding: 18px 24px; border: none; border-radius: 14px;
      font-family: 'Sora', sans-serif; font-weight: 800; font-size: 1.05rem;
      cursor: pointer; transition: all 0.3s; position: relative; overflow: hidden;
      background: linear-gradient(135deg, #1DB8E8, #5DD4F4); color: #fff;
      box-shadow: 0 8px 32px rgba(29,184,232,0.35);
    }
    .ax-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(29,184,232,0.5); }
    .ax-cta:active { transform: translateY(0); }
    .ax-cta-gold { background: linear-gradient(135deg, #C9A84C, #e8c96a); box-shadow: 0 8px 32px rgba(201,168,76,0.35); }
    .ax-cta-gold:hover { box-shadow: 0 12px 40px rgba(201,168,76,0.5); }

    /* Social proof */
    .ax-social { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 1.25rem; }
    .ax-social-avatars { display: flex; }
    .ax-social-avatars span { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; border: 2px solid #0D1B3E; margin-left: -8px; }
    .ax-social-avatars span:first-child { margin-left: 0; }
    .ax-social-text { font-size: 0.75rem; color: rgba(255,255,255,0.4); }
    .ax-social-text strong { color: rgba(255,255,255,0.6); }

    /* Disclaimer */
    .ax-disclaimer { background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.2); border-radius: 12px; padding: 14px 16px; margin-top: 1.5rem; }
    .ax-disclaimer p { font-size: 0.78rem; color: rgba(201,168,76,0.8); line-height: 1.55; margin: 0; text-align: center; }
    .ax-disclaimer strong { color: rgba(201,168,76,1); }

    /* Interstitial */
    .ax-interstitial { text-align: center; padding: 4rem 0; }
    .ax-interstitial-icon { font-size: 3rem; margin-bottom: 1.5rem; display: inline-block; }
    .ax-interstitial h2 { font-family: 'Sora', sans-serif; font-size: 1.3rem; font-weight: 800; color: #fff; margin: 0 0 0.75rem; line-height: 1.3; }
    .ax-interstitial p { font-size: 0.95rem; color: rgba(255,255,255,0.55); line-height: 1.7; margin: 0; max-width: 380px; margin-left: auto; margin-right: auto; }
    .ax-stat { display: inline-block; font-family: 'Sora', sans-serif; font-size: 2.5rem; font-weight: 900; background: linear-gradient(135deg, #1DB8E8, #5DD4F4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem; }

    /* Loading screen */
    .ax-loading { text-align: center; padding: 4rem 0; }
    .ax-spinner { width: 60px; height: 60px; border: 3px solid rgba(29,184,232,0.15); border-top-color: #1DB8E8; border-radius: 50%; animation: axSpin 0.8s linear infinite; margin: 0 auto 2rem; }
    .ax-loading-steps { display: flex; flex-direction: column; gap: 14px; max-width: 300px; margin: 0 auto; text-align: left; }
    .ax-loading-step { display: flex; align-items: center; gap: 12px; font-size: 0.88rem; color: rgba(255,255,255,0.3); transition: color 0.5s; }
    .ax-loading-step.done { color: rgba(255,255,255,0.8); }
    .ax-loading-step .ax-check { width: 22px; height: 22px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; transition: all 0.5s; flex-shrink: 0; }
    .ax-loading-step.done .ax-check { border-color: #1DB8E8; background: #1DB8E8; color: #fff; }

    /* Email gate */
    .ax-email-gate { padding: 2rem 0; }
    .ax-email-preview { position: relative; margin-bottom: 2rem; }
    .ax-email-blur { filter: blur(8px); pointer-events: none; opacity: 0.5; }
    .ax-email-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; }
    .ax-email-lock { background: rgba(13,27,62,0.9); border: 1px solid rgba(29,184,232,0.2); border-radius: 16px; padding: 1.5rem 2rem; text-align: center; backdrop-filter: blur(4px); }
    .ax-email-lock p { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin: 0.5rem 0 0; }
    .ax-input { width: 100%; padding: 16px 20px; border: 2px solid rgba(255,255,255,0.1); border-radius: 12px; font-family: 'DM Sans', sans-serif; font-size: 0.95rem; color: #fff; outline: none; transition: border-color 0.2s; background: rgba(255,255,255,0.04); box-sizing: border-box; }
    .ax-input::placeholder { color: rgba(255,255,255,0.25); }
    .ax-input:focus { border-color: #1DB8E8; background: rgba(29,184,232,0.04); }
    .ax-input.error { border-color: #e74c3c; }
    .ax-skip { background: none; border: none; color: rgba(255,255,255,0.3); font-size: 0.78rem; cursor: pointer; margin-top: 1rem; font-family: 'DM Sans', sans-serif; transition: color 0.2s; }
    .ax-skip:hover { color: rgba(255,255,255,0.6); }

    /* Result */
    .ax-result { padding: 1rem 0 3rem; }
    .ax-score-wrap { text-align: center; margin-bottom: 2rem; }
    .ax-score-ring { position: relative; width: 200px; height: 200px; margin: 0 auto 1rem; }
    .ax-score-ring svg { transform: rotate(-90deg); }
    .ax-score-val { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; }
    .ax-score-num { font-family: 'Sora', sans-serif; font-size: 3rem; font-weight: 900; animation: axCountUp 0.8s ease-out; }
    .ax-score-label { font-size: 0.75rem; color: rgba(255,255,255,0.4); }
    .ax-level-badge { display: inline-flex; align-items: center; gap: 6px; padding: 8px 20px; border-radius: 24px; font-family: 'Sora', sans-serif; font-weight: 700; font-size: 0.88rem; }
    .ax-level-desc { font-size: 0.95rem; color: rgba(255,255,255,0.6); line-height: 1.7; text-align: center; margin: 1rem 0 2rem; max-width: 440px; margin-left: auto; margin-right: auto; }

    /* Symptom cards */
    .ax-symptom { padding: 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; margin-bottom: 12px; }
    .ax-symptom-head { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
    .ax-symptom-icon { font-size: 1.2rem; }
    .ax-symptom-name { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 0.92rem; color: #fff; }
    .ax-symptom-level { font-size: 0.72rem; font-weight: 700; padding: 2px 10px; border-radius: 10px; margin-left: auto; }
    .ax-symptom-tip { font-size: 0.85rem; color: rgba(255,255,255,0.5); line-height: 1.6; margin: 0 0 6px; }
    .ax-symptom-link { font-size: 0.82rem; color: #1DB8E8; text-decoration: none; font-weight: 600; }
    .ax-symptom-link:hover { text-decoration: underline; }

    /* Scale bar */
    .ax-scale-bar { position: relative; height: 10px; border-radius: 5px; margin: 1rem 0; overflow: visible; }
    .ax-scale-marker { position: absolute; top: -4px; width: 18px; height: 18px; border-radius: 50%; border: 3px solid rgba(13,27,62,1); box-shadow: 0 2px 8px rgba(0,0,0,0.3); transform: translateX(-50%); transition: left 1.5s ease-out; }
    .ax-scale-labels { display: flex; justify-content: space-between; margin-top: 6px; }
    .ax-scale-label { font-size: 0.65rem; color: rgba(255,255,255,0.3); }

    /* Product CTA */
    .ax-product { background: linear-gradient(135deg, rgba(29,184,232,0.1), rgba(29,184,232,0.04)); border: 1px solid rgba(29,184,232,0.2); border-radius: 18px; padding: 2rem; text-align: center; margin: 2rem 0; }
    .ax-product h3 { font-family: 'Sora', sans-serif; font-size: 1.1rem; font-weight: 800; color: #fff; margin: 0 0 0.5rem; }
    .ax-product p { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin: 0 0 1.25rem; }
    .ax-product-pills { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 1.25rem; }
    .ax-pill { padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; background: rgba(29,184,232,0.1); color: #1DB8E8; border: 1px solid rgba(29,184,232,0.2); }

    /* SEO section */
    .ax-seo { padding: 3rem 1.5rem; background: #F4F8FC; }
    .ax-seo-card { max-width: 680px; margin: 0 auto 2rem; background: #fff; border-radius: 18px; padding: 2rem; border: 1px solid #e8eef6; }
    .ax-seo-card h2 { font-family: 'Sora', sans-serif; font-size: 1.3rem; font-weight: 800; color: #0D1B3E; margin: 0 0 1rem; }
    .ax-seo-card p { font-size: 0.95rem; color: #3A4A6B; line-height: 1.8; margin: 0 0 1rem; }
    .ax-seo-card p:last-child { margin-bottom: 0; }
    .ax-seo-links { max-width: 680px; margin: 0 auto 2rem; background: #fff; border-radius: 18px; padding: 2rem; border: 1px solid #e8eef6; }
    .ax-seo-links h3 { font-family: 'Sora', sans-serif; font-size: 1.1rem; font-weight: 700; color: #0D1B3E; margin: 0 0 1rem; }
    .ax-seo-links a { color: #1DB8E8; text-decoration: none; font-weight: 600; font-size: 0.92rem; display: block; padding: 6px 0; }
    .ax-seo-links a:hover { text-decoration: underline; }

    @media (max-width: 480px) {
      .ax-question { font-size: 1.1rem; }
      .ax-score-ring { width: 160px; height: 160px; }
      .ax-score-num { font-size: 2.4rem; }
      .ax-option { padding: 14px 16px; }
    }
  </style>

  <!-- ===== ANXIETY TEST FULLSCREEN ===== -->
  <div class="ax-wrap" id="ax-app">

    <!-- Progress bar -->
    <div class="ax-progress"><div class="ax-progress-fill" id="ax-progress" style="width: 0%;"></div></div>

    <div class="ax-container">

      <!-- Top bar (hidden on start) -->
      <div class="ax-topbar" id="ax-topbar" style="visibility: hidden;">
        <button type="button" class="ax-topbar-back" id="ax-back" onclick="axPrev()">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="ax-topbar-step" id="ax-step"></span>
        <a href="/blog/" style="font-size: 0.72rem; color: rgba(255,255,255,0.25); text-decoration: none;">Sair</a>
      </div>

      <!-- SCREEN: Start -->
      <div class="ax-screen active" id="scr-start">
        <div class="ax-hero">
          <span class="ax-hero-icon">🧘</span>
          <div class="ax-clinical">
            <span class="ax-clinical-icon">🏥</span>
            <span class="ax-clinical-text">Baseado na escala clínica GAD-7</span>
          </div>
          <h1>Como Está Sua<br/><span>Ansiedade</span>?</h1>
          <p>Avalie seu nível de ansiedade com base na escala GAD-7 — usada por psicólogos e psiquiatras no mundo todo.</p>

          <div class="ax-features">
            <div class="ax-feature">
              <span class="ax-feature-icon">📋</span>
              <span class="ax-feature-text"><strong>Escala GAD-7</strong> validada cientificamente</span>
            </div>
            <div class="ax-feature">
              <span class="ax-feature-icon">📊</span>
              <span class="ax-feature-text">Score de <strong>0 a 21</strong> com classificação</span>
            </div>
            <div class="ax-feature">
              <span class="ax-feature-icon">💡</span>
              <span class="ax-feature-text"><strong>Recomendações</strong> baseadas no seu perfil</span>
            </div>
          </div>

          <button type="button" class="ax-cta" onclick="axStart()">
            Iniciar avaliação gratuita
          </button>

          <div class="ax-social">
            <div class="ax-social-avatars">
              <span style="background:#5DD4F4;">👩</span>
              <span style="background:#C9A84C;">👨</span>
              <span style="background:#5B6FDE;">👩</span>
              <span style="background:#0fa36b;">👨</span>
            </div>
            <span class="ax-social-text"><strong>4.312 pessoas</strong> já avaliaram</span>
          </div>

          <div class="ax-disclaimer">
            <p><strong>Aviso:</strong> Este teste é informativo e educacional. Não substitui avaliação profissional. Se sua ansiedade está prejudicando sua vida, procure um psicólogo ou psiquiatra.</p>
          </div>
        </div>
      </div>

      <!-- SCREEN: Questions (rendered dynamically) -->
      <div class="ax-screen" id="scr-question">
        <p class="ax-question-label">Nas últimas 2 semanas, com que frequência...</p>
        <h2 class="ax-question" id="ax-question"></h2>
        <div id="ax-options"></div>
      </div>

      <!-- SCREEN: Interstitial 1 (after Q3) -->
      <div class="ax-screen" id="scr-inter1">
        <div class="ax-interstitial">
          <span class="ax-interstitial-icon">🔬</span>
          <h2>Estamos mapeando seus padrões...</h2>
          <p>Já identificamos tendências importantes no seu perfil. Mais 4 perguntas para uma avaliação completa.</p>
        </div>
      </div>

      <!-- SCREEN: Interstitial 2 (after Q5) -->
      <div class="ax-screen" id="scr-inter2">
        <div class="ax-interstitial">
          <div class="ax-stat">72%</div>
          <h2>das pessoas com perfil similar reduziram a ansiedade com mudanças simples</h2>
          <p>Quase lá! Mais 2 perguntas para finalizar sua avaliação.</p>
        </div>
      </div>

      <!-- SCREEN: Loading / Analysis -->
      <div class="ax-screen" id="scr-loading">
        <div class="ax-loading">
          <div class="ax-spinner"></div>
          <h2 style="font-family:'Sora',sans-serif; font-size:1.2rem; font-weight:800; color:#fff; margin:0 0 2rem;">Analisando seu perfil de ansiedade...</h2>
          <div class="ax-loading-steps">
            <div class="ax-loading-step" id="load-1"><span class="ax-check">✓</span> Calculando score GAD-7</div>
            <div class="ax-loading-step" id="load-2"><span class="ax-check">✓</span> Classificando nível de ansiedade</div>
            <div class="ax-loading-step" id="load-3"><span class="ax-check">✓</span> Gerando recomendações personalizadas</div>
          </div>
        </div>
      </div>

      <!-- SCREEN: Email Gate -->
      <div class="ax-screen" id="scr-email">
        <div class="ax-email-gate">
          <div style="text-align:center; margin-bottom:2rem;">
            <span style="font-size:2.5rem; display:inline-block; margin-bottom:0.75rem;">🎯</span>
            <h2 style="font-family:'Sora',sans-serif; font-size:1.25rem; font-weight:800; color:#fff; margin:0 0 0.5rem;">Sua avaliação está pronta!</h2>
            <p style="font-size:0.9rem; color:rgba(255,255,255,0.5); line-height:1.6; margin:0;">Para onde enviamos seu relatório completo?</p>
          </div>

          <!-- Blurred preview -->
          <div class="ax-email-preview">
            <div class="ax-email-blur" id="ax-blur-preview"></div>
            <div class="ax-email-overlay">
              <div class="ax-email-lock">
                <span style="font-size:1.5rem;">🔒</span>
                <p>Informe seu email para desbloquear</p>
              </div>
            </div>
          </div>

          <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:1rem;">
            <input type="text" id="ax-name" class="ax-input" placeholder="Seu primeiro nome" />
            <input type="email" id="ax-email" class="ax-input" placeholder="Seu melhor email" />
          </div>
          <button type="button" class="ax-cta" onclick="axSubmitEmail()" id="ax-btn-email">
            Ver meu relatório completo
          </button>
          <div style="text-align:center;">
            <button type="button" class="ax-skip" onclick="axSkipEmail()">Pular e ver resultado resumido</button>
          </div>
          <p style="font-size:0.68rem; color:rgba(255,255,255,0.2); text-align:center; margin:1rem 0 0; line-height:1.5;">
            Seus dados estão seguros. Sem spam. Cancele quando quiser.
          </p>
        </div>
      </div>

      <!-- SCREEN: Result -->
      <div class="ax-screen" id="scr-result">
        <div class="ax-result" id="ax-result-content"></div>
      </div>

    </div>
  </div>

  <!-- SEO content below quiz -->
  <div class="ax-seo">
    <div class="ax-seo-card">
      <h2>Sobre a escala GAD-7</h2>
      <p>O GAD-7 (Generalized Anxiety Disorder 7-item scale) é uma das escalas mais utilizadas mundialmente para rastreamento de ansiedade generalizada. Foi desenvolvida por Spitzer, Kroenke e Williams em 2006 e é validada em português brasileiro.</p>
      <p>A escala avalia a frequência de 7 sintomas nas últimas 2 semanas, gerando um score de 0 a 21. Não é um diagnóstico — é uma ferramenta de rastreamento que indica quando buscar ajuda profissional.</p>
    </div>
    <div class="ax-seo-card">
      <h2>Faixas de classificação</h2>
      <p><strong>0 a 4 — Ansiedade Mínima:</strong> Sintomas dentro do normal. Manter hábitos saudáveis é suficiente.</p>
      <p><strong>5 a 9 — Ansiedade Leve:</strong> Sintomas perceptíveis, mas geralmente manejáveis com mudanças de hábitos e suporte nutricional.</p>
      <p><strong>10 a 14 — Ansiedade Moderada:</strong> Impacto na qualidade de vida. Considerar acompanhamento profissional.</p>
      <p><strong>15 a 21 — Ansiedade Severa:</strong> Buscar ajuda profissional. Psicoterapia e, em alguns casos, tratamento medicamentoso.</p>
    </div>
    <div class="ax-seo-links">
      <h3>Artigos relacionados</h3>
      <a href="/blog/como-controlar-ansiedade-naturalmente/">Como controlar ansiedade naturalmente</a>
      <a href="/blog/ansiedade-noite-por-que-piora-ao-deitar/">Por que a ansiedade piora à noite</a>
      <a href="/blog/crise-de-ansiedade-agora-protocolo-5-minutos/">Crise de ansiedade: protocolo de 5 minutos</a>
      <a href="/blog/respiracao-para-ansiedade-tecnicas/">Técnicas de respiração para ansiedade</a>
    </div>
    <div style="text-align:center; padding-bottom:3rem;">
      <a href="/blog/" style="font-weight:700; color:#1DB8E8; text-decoration:none; font-size:0.95rem;">← Voltar para o blog</a>
    </div>
  </div>

  <script is:inline>
    /* ===== DATA ===== */
    var AX = {
      questions: [
        { q: 'Sentir-se nervoso(a), ansioso(a) ou muito tenso(a)', icon: '😰',
          symptom: 'nervosismo' },
        { q: 'Não ser capaz de impedir ou controlar as preocupações', icon: '🌀',
          symptom: 'preocupacao' },
        { q: 'Preocupar-se muito com diversas coisas', icon: '💭',
          symptom: 'ruminacao' },
        { q: 'Dificuldade para relaxar', icon: '😤',
          symptom: 'tensao' },
        { q: 'Ficar tão inquieto(a) que é difícil ficar parado(a)', icon: '🦶',
          symptom: 'inquietacao' },
        { q: 'Ficar facilmente irritado(a) ou aborrecido(a)', icon: '😠',
          symptom: 'irritabilidade' },
        { q: 'Sentir medo como se algo horrível fosse acontecer', icon: '😨',
          symptom: 'medo' },
      ],
      scaleOpts: [
        { text: 'Nenhuma vez', icon: '😌', score: 0 },
        { text: 'Vários dias', icon: '😐', score: 1 },
        { text: 'Mais da metade dos dias', icon: '😟', score: 2 },
        { text: 'Quase todos os dias', icon: '😣', score: 3 },
      ],
      interstitials: { 3: 'scr-inter1', 5: 'scr-inter2' },
      current: 0,
      answers: [],
      hasEmail: false,
    };

    AX.answers = new Array(AX.questions.length).fill(-1);

    var symptomData = {
      nervosismo:    { name: 'Nervosismo e tensão', icon: '😰', tip: 'A ativação crônica do sistema nervoso simpático mantém o corpo em estado de alerta. Magnésio e técnicas de respiração ativam o sistema parassimpático.', link: '/blog/como-controlar-ansiedade-naturalmente/' },
      preocupacao:   { name: 'Preocupação incontrolável', icon: '🌀', tip: 'A ruminação ativa o córtex pré-frontal de forma disfuncional. Triptofano (precursor da serotonina) ajuda a regular esse circuito.', link: '/blog/ansiedade-noite-por-que-piora-ao-deitar/' },
      ruminacao:     { name: 'Pensamentos excessivos', icon: '💭', tip: 'Pensar demais consome serotonina cerebral. Suplementação com triptofano e vitamina B6 ajuda na reposição.', link: '/blog/pensamentos-acelerados-como-parar/' },
      tensao:        { name: 'Dificuldade para relaxar', icon: '😤', tip: 'O sistema GABA é o principal calmante do cérebro. Magnésio é cofator essencial para a ativação do GABA.', link: '/blog/respiracao-para-ansiedade-tecnicas/' },
      inquietacao:   { name: 'Inquietação física', icon: '🦶', tip: 'A agitação motora é sinal de excesso de cortisol. Exercício físico e magnésio ajudam a regular.', link: '/blog/exercicio-fisico-melhora-sono/' },
      irritabilidade:{ name: 'Irritabilidade', icon: '😠', tip: 'A irritabilidade frequente pode indicar depleção de serotonina e magnésio. São os dois nutrientes mais consumidos pelo estresse.', link: '/blog/como-controlar-ansiedade-naturalmente/' },
      medo:          { name: 'Medo e apreensão', icon: '😨', tip: 'A amígdala hiper-reativa gera sensação constante de perigo. Melatonina noturna e sono de qualidade ajudam a recalibrar esse sistema.', link: '/blog/crise-de-ansiedade-agora-protocolo-5-minutos/' },
    };

    /* ===== SCREEN MANAGEMENT ===== */
    function axShowScreen(id) {
      document.querySelectorAll('.ax-screen').forEach(function(el) { el.classList.remove('active'); });
      document.getElementById(id).classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function axUpdateProgress() {
      var pct = Math.round(((AX.current + 1) / AX.questions.length) * 100);
      document.getElementById('ax-progress').style.width = pct + '%';
      document.getElementById('ax-step').textContent = (AX.current + 1) + ' de ' + AX.questions.length;
    }

    /* ===== START ===== */
    function axStart() {
      document.getElementById('ax-topbar').style.visibility = 'visible';
      AX.current = 0;
      axUpdateProgress();
      axRenderQuestion();
      axShowScreen('scr-question');
    }

    /* ===== RENDER QUESTION ===== */
    function axRenderQuestion() {
      var q = AX.questions[AX.current];
      document.getElementById('ax-question').textContent = q.q;
      axUpdateProgress();

      var wrap = document.getElementById('ax-options');
      wrap.innerHTML = '';

      AX.scaleOpts.forEach(function(opt, i) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'ax-option' + (AX.answers[AX.current] === i ? ' selected' : '');

        var iconDiv = document.createElement('span');
        iconDiv.className = 'ax-opt-icon';
        iconDiv.textContent = opt.icon;

        var textDiv = document.createElement('span');
        textDiv.className = 'ax-opt-text';
        textDiv.textContent = opt.text;

        var checkDiv = document.createElement('span');
        checkDiv.className = 'ax-opt-check';
        checkDiv.textContent = '✓';

        btn.appendChild(iconDiv);
        btn.appendChild(textDiv);
        btn.appendChild(checkDiv);

        btn.addEventListener('click', function() { axSelect(i); });
        wrap.appendChild(btn);
      });
    }

    /* ===== SELECT OPTION (auto-advance) ===== */
    function axSelect(i) {
      AX.answers[AX.current] = i;

      document.querySelectorAll('.ax-option').forEach(function(el, idx) {
        el.classList.toggle('selected', idx === i);
      });

      setTimeout(function() {
        axNext();
      }, 400);
    }

    /* ===== NAVIGATION ===== */
    function axNext() {
      if (AX.current < AX.questions.length - 1) {
        AX.current++;
        if (AX.interstitials[AX.current]) {
          axShowScreen(AX.interstitials[AX.current]);
          setTimeout(function() {
            axRenderQuestion();
            axShowScreen('scr-question');
          }, 2200);
        } else {
          axRenderQuestion();
          axShowScreen('scr-question');
        }
      } else {
        axShowLoading();
      }
    }

    function axPrev() {
      if (AX.current > 0) {
        AX.current--;
        axUpdateProgress();
        axRenderQuestion();
        axShowScreen('scr-question');
      } else {
        document.getElementById('ax-topbar').style.visibility = 'hidden';
        axShowScreen('scr-start');
        document.getElementById('ax-progress').style.width = '0%';
      }
    }

    /* ===== LOADING ANIMATION ===== */
    function axShowLoading() {
      document.getElementById('ax-progress').style.width = '100%';
      axShowScreen('scr-loading');

      var steps = ['load-1', 'load-2', 'load-3'];
      steps.forEach(function(id, idx) {
        setTimeout(function() {
          document.getElementById(id).classList.add('done');
        }, 800 * (idx + 1));
      });

      setTimeout(function() {
        axShowEmailGate();
      }, 3200);
    }

    /* ===== SCORE CALCULATION ===== */
    function axCalcScore() {
      var total = 0;
      for (var i = 0; i < AX.answers.length; i++) {
        total += AX.scaleOpts[AX.answers[i]].score;
      }
      return total;
    }

    function axGetLevel(score) {
      if (score <= 4) return { label: 'Ansiedade Mínima', color: '#0fa36b', bg: 'rgba(15,163,107,0.12)', border: 'rgba(15,163,107,0.3)', emoji: '🟢',
        desc: 'Seus níveis de ansiedade estão dentro do normal. Continue mantendo seus hábitos saudáveis e práticas de autocuidado.' };
      if (score <= 9) return { label: 'Ansiedade Leve', color: '#C9A84C', bg: 'rgba(201,168,76,0.12)', border: 'rgba(201,168,76,0.3)', emoji: '🟡',
        desc: 'Você apresenta sintomas leves de ansiedade. São comuns e geralmente manejáveis com mudanças de hábitos e suporte nutricional.' };
      if (score <= 14) return { label: 'Ansiedade Moderada', color: '#e67e22', bg: 'rgba(230,126,34,0.12)', border: 'rgba(230,126,34,0.3)', emoji: '🟠',
        desc: 'Seus sintomas indicam ansiedade moderada. Este nível já pode impactar sua qualidade de vida, sono e produtividade.' };
      return { label: 'Ansiedade Severa', color: '#e74c3c', bg: 'rgba(231,76,60,0.12)', border: 'rgba(231,76,60,0.3)', emoji: '🔴',
        desc: 'Seus sintomas indicam ansiedade severa. É importante buscar acompanhamento profissional — psicoterapia é altamente eficaz.' };
    }

    function axGetWorstSymptoms() {
      var scored = [];
      for (var i = 0; i < AX.answers.length; i++) {
        scored.push({ key: AX.questions[i].symptom, score: AX.scaleOpts[AX.answers[i]].score });
      }
      scored.sort(function(a, b) { return b.score - a.score; });
      return scored.filter(function(s) { return s.score >= 2; }).slice(0, 3);
    }

    /* ===== EMAIL GATE ===== */
    function axShowEmailGate() {
      var score = axCalcScore();
      var level = axGetLevel(score);

      var r = 60, circ = 2 * Math.PI * r, offset = circ - (score / 21) * circ;
      document.getElementById('ax-blur-preview').innerHTML =
        '<div style="text-align:center;padding:2rem 1rem;">' +
          '<svg width="140" height="140" style="transform:rotate(-90deg);">' +
            '<circle cx="70" cy="70" r="' + r + '" stroke="rgba(255,255,255,0.08)" stroke-width="8" fill="none"/>' +
            '<circle cx="70" cy="70" r="' + r + '" stroke="' + level.color + '" stroke-width="8" fill="none" stroke-dasharray="' + circ + '" stroke-dashoffset="' + offset + '" stroke-linecap="round"/>' +
          '</svg>' +
          '<div style="font-family:Sora,sans-serif;font-size:1.5rem;font-weight:900;color:' + level.color + ';margin-top:-90px;position:relative;">' + score + '<span style="font-size:0.8rem;color:rgba(255,255,255,0.3);">/21</span></div>' +
          '<div style="font-size:0.7rem;color:rgba(255,255,255,0.3);margin-top:55px;">Score GAD-7</div>' +
          '<div style="margin-top:1rem;display:inline-block;padding:6px 14px;border-radius:16px;background:' + level.bg + ';border:1px solid ' + level.border + ';font-size:0.8rem;font-weight:700;color:' + level.color + ';">' + level.emoji + ' ' + level.label + '</div>' +
        '</div>';

      axShowScreen('scr-email');
    }

    function axSubmitEmail() {
      var name = document.getElementById('ax-name').value.trim();
      var email = document.getElementById('ax-email').value.trim();
      if (!email || !email.includes('@') || !email.includes('.')) {
        document.getElementById('ax-email').classList.add('error');
        return;
      }
      document.getElementById('ax-email').classList.remove('error');
      AX.hasEmail = true;

      // Disable button while saving
      var btn = document.getElementById('ax-btn-email');
      if (btn) { btn.disabled = true; btn.textContent = 'Salvando...'; }

      // Save lead to Supabase via API
      fetch('/blog/api/quiz-lead/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, email: email, quiz: 'ansiedade', score: axCalcScore() })
      })
      .then(function(r) { return r.json(); })
      .then(function() { axShowResult(true, name); })
      .catch(function() { axShowResult(true, name); }); // show result even if API fails
    }

    function axSkipEmail() {
      axShowResult(false, '');
    }

    /* ===== RESULT ===== */
    function axShowResult(full, userName) {
      var score = axCalcScore();
      var level = axGetLevel(score);
      var worst = axGetWorstSymptoms();

      var r = 88, circ = 2 * Math.PI * r, offset = circ - (score / 21) * circ;

      var html = '';

      if (userName) {
        html += '<p style="text-align:center;font-size:0.85rem;color:rgba(255,255,255,0.4);margin:0 0 0.25rem;">Resultado de</p>';
        html += '<p style="text-align:center;font-family:Sora,sans-serif;font-size:1.1rem;font-weight:700;color:#fff;margin:0 0 1.5rem;">' + userName + '</p>';
      }

      /* Score ring */
      html += '<div class="ax-score-wrap">' +
        '<div class="ax-score-ring">' +
          '<svg width="200" height="200">' +
            '<circle cx="100" cy="100" r="' + r + '" stroke="rgba(255,255,255,0.06)" stroke-width="10" fill="none"/>' +
            '<circle cx="100" cy="100" r="' + r + '" stroke="' + level.color + '" stroke-width="10" fill="none" stroke-dasharray="' + circ + '" stroke-dashoffset="' + offset + '" stroke-linecap="round" style="transition:stroke-dashoffset 1.5s ease-out;"/>' +
          '</svg>' +
          '<div class="ax-score-val">' +
            '<div class="ax-score-num" style="color:' + level.color + ';">' + score + '<span style="font-size:1.2rem;color:rgba(255,255,255,0.3);">/21</span></div>' +
            '<div class="ax-score-label">Score GAD-7</div>' +
          '</div>' +
        '</div>' +
        '<span class="ax-level-badge" style="background:' + level.bg + ';border:1px solid ' + level.border + ';color:' + level.color + ';">' + level.emoji + ' ' + level.label + '</span>' +
      '</div>';

      /* Scale bar */
      var pct = Math.max(3, Math.round((score / 21) * 100));
      html += '<div style="margin:1.5rem 0;">' +
        '<div class="ax-scale-bar" style="background:linear-gradient(90deg,rgba(15,163,107,0.5) 0%,rgba(201,168,76,0.5) 33%,rgba(230,126,34,0.5) 66%,rgba(231,76,60,0.5) 100%);">' +
          '<div class="ax-scale-marker" style="left:' + pct + '%;background:' + level.color + ';"></div>' +
        '</div>' +
        '<div class="ax-scale-labels">' +
          '<span class="ax-scale-label">Mínima</span>' +
          '<span class="ax-scale-label">Leve</span>' +
          '<span class="ax-scale-label">Moderada</span>' +
          '<span class="ax-scale-label">Severa</span>' +
        '</div>' +
      '</div>';

      html += '<p class="ax-level-desc">' + level.desc + '</p>';

      /* Worst symptoms */
      if (worst.length > 0) {
        html += '<h3 style="font-family:Sora,sans-serif;font-size:1rem;font-weight:700;color:#fff;margin:0 0 1rem;">';
        html += full ? '🔍 Sintomas mais frequentes no seu perfil:' : 'Seus principais sintomas:';
        html += '</h3>';

        worst.forEach(function(item) {
          var s = symptomData[item.key];
          var freqLabel = item.score === 3 ? 'Diário' : 'Frequente';
          var freqColor = item.score === 3 ? '#e74c3c' : '#e67e22';
          var freqBg = item.score === 3 ? 'rgba(231,76,60,0.12)' : 'rgba(230,126,34,0.12)';

          html += '<div class="ax-symptom">' +
            '<div class="ax-symptom-head">' +
              '<span class="ax-symptom-icon">' + s.icon + '</span>' +
              '<span class="ax-symptom-name">' + s.name + '</span>' +
              '<span class="ax-symptom-level" style="background:' + freqBg + ';color:' + freqColor + ';">' + freqLabel + '</span>' +
            '</div>';
          if (full) {
            html += '<p class="ax-symptom-tip">' + s.tip + '</p>' +
              '<a href="' + s.link + '" class="ax-symptom-link">Ler artigo completo →</a>';
          }
          html += '</div>';
        });
      }

      /* Recommendations for full result */
      if (full && score >= 5) {
        html += '<div style="margin-top:1.5rem;padding:20px;background:rgba(29,184,232,0.06);border:1px solid rgba(29,184,232,0.12);border-radius:14px;">' +
          '<h3 style="font-family:Sora,sans-serif;font-size:1rem;font-weight:700;color:#fff;margin:0 0 1rem;">💡 O que pode ajudar:</h3>' +
          '<div style="display:flex;flex-direction:column;gap:12px;">';

        var recs = [
          { icon: '🫁', title: 'Respiração 4-7-8', desc: 'Ativa o nervo vago e reduz cortisol em 2-3 minutos. Inspire 4s, segure 7s, expire 8s.' },
          { icon: '🏃', title: 'Exercício regular', desc: 'Tão eficaz quanto medicação para ansiedade leve a moderada. 30 min, 3x por semana.' },
          { icon: '🌙', title: 'Higiene do sono', desc: 'Sono ruim aumenta ansiedade em até 30%. Horário fixo e ambiente escuro são essenciais.' },
          { icon: '🧪', title: 'Suporte bioquímico', desc: 'Magnésio ativa o GABA (calmante natural). Triptofano é precursor da serotonina.' },
        ];

        if (score >= 10) {
          recs.push({ icon: '🧠', title: 'Acompanhamento profissional', desc: 'Terapia Cognitivo-Comportamental (TCC) é o tratamento mais eficaz para ansiedade.' });
        }

        recs.forEach(function(r) {
          html += '<div style="display:flex;gap:12px;align-items:flex-start;">' +
            '<span style="font-size:1.3rem;flex-shrink:0;margin-top:2px;">' + r.icon + '</span>' +
            '<div>' +
              '<p style="font-family:Sora,sans-serif;font-weight:700;font-size:0.88rem;color:#fff;margin:0 0 2px;">' + r.title + '</p>' +
              '<p style="font-size:0.82rem;color:rgba(255,255,255,0.45);line-height:1.5;margin:0;">' + r.desc + '</p>' +
            '</div>' +
          '</div>';
        });

        html += '</div></div>';
      }

      /* Connection: Anxiety ↔ Sleep */
      if (full) {
        html += '<div style="margin-top:1.5rem;padding:20px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:14px;">' +
          '<h3 style="font-family:Sora,sans-serif;font-size:0.95rem;font-weight:700;color:#fff;margin:0 0 0.75rem;">🔄 O ciclo ansiedade ↔ sono</h3>' +
          '<p style="font-size:0.85rem;color:rgba(255,255,255,0.5);line-height:1.7;margin:0;">' +
            'Ansiedade e sono ruim formam um ciclo vicioso: a ansiedade impede o relaxamento para dormir, e a privação de sono amplifica a ansiedade em até 30%. Quebrar esse ciclo é fundamental — e começa por apoiar a bioquímica cerebral com magnésio, triptofano e melatonina.' +
          '</p>' +
        '</div>';
      }

      /* Product CTA */
      if (full) {
        var productTitle = score >= 10 ? 'Cuide da bioquímica enquanto busca ajuda profissional' : 'Reforce seu equilíbrio emocional naturalmente';
        var productDesc = score >= 10
          ? 'Com ansiedade moderada a severa, técnicas comportamentais sozinhas podem não ser suficientes. Magnésio + triptofano + vitamina B6 atuam diretamente no sistema GABA e serotonina.'
          : 'Pequenos ajustes bioquímicos podem fazer grande diferença. Magnésio ativa o GABA (calmante natural) e triptofano é precursor da serotonina (regulador do humor).';

        var pills = ['Magnésio', 'Triptofano'];
        if (score >= 10) pills.push('Melatonina');
        pills.push('Vitamina B6');

        html += '<div class="ax-product">' +
          '<p style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#1DB8E8;margin:0 0 0.5rem;">Recomendação baseada no seu perfil</p>' +
          '<h3>' + productTitle + '</h3>' +
          '<p>' + productDesc + '</p>' +
          '<div class="ax-product-pills">';
        pills.forEach(function(p) { html += '<span class="ax-pill">' + p + '</span>'; });
        html += '</div>' +
          '<a href="https://zencaps.com.br" target="_blank" rel="noopener" class="ax-cta ax-cta-gold" style="display:inline-block;width:auto;padding:14px 32px;text-decoration:none;font-size:0.95rem;">Conhecer Zen Caps →</a>' +
        '</div>';
      } else {
        html += '<div style="margin-top:2rem;padding:1.25rem;background:rgba(29,184,232,0.06);border:1px solid rgba(29,184,232,0.15);border-radius:14px;text-align:center;">' +
          '<p style="font-size:0.88rem;color:rgba(255,255,255,0.6);margin:0 0 0.75rem;">Quer o relatório completo com recomendações?</p>' +
          '<button type="button" class="ax-cta" onclick="axShowScreen(\'scr-email\')" style="font-size:0.88rem;padding:12px 24px;">Desbloquear resultado completo</button>' +
        '</div>';
      }

      /* Medical disclaimer */
      html += '<div class="ax-disclaimer" style="margin-top:1.5rem;">' +
        '<p><strong>⚠️ Aviso importante:</strong> Este teste é informativo e educacional. Se sua ansiedade está afetando sua vida, procure um psicólogo ou psiquiatra. Ansiedade é tratável.</p>' +
      '</div>';

      /* Share & restart */
      html += '<div style="display:flex;gap:12px;justify-content:center;margin-top:2rem;flex-wrap:wrap;">' +
        '<button type="button" onclick="axReset()" style="background:none;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);padding:10px 20px;border-radius:10px;cursor:pointer;font-family:DM Sans,sans-serif;font-size:0.85rem;transition:all 0.2s;">Refazer teste</button>' +
        '<a href="/blog/quiz-do-sono/" style="display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);padding:10px 20px;border-radius:10px;text-decoration:none;font-size:0.85rem;transition:all 0.2s;">🌙 Quiz do Sono</a>' +
        '<a href="/blog/" style="display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);padding:10px 20px;border-radius:10px;text-decoration:none;font-size:0.85rem;transition:all 0.2s;">← Voltar ao blog</a>' +
      '</div>';

      document.getElementById('ax-result-content').innerHTML = html;
      axShowScreen('scr-result');
    }

    function axReset() {
      AX.current = 0;
      AX.answers = new Array(AX.questions.length).fill(-1);
      AX.hasEmail = false;
      document.getElementById('ax-progress').style.width = '0%';
      document.getElementById('ax-topbar').style.visibility = 'hidden';
      ['load-1','load-2','load-3'].forEach(function(id) { document.getElementById(id).classList.remove('done'); });
      axShowScreen('scr-start');
    }
  </script>
</BlogLayout>
