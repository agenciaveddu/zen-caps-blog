---
import BlogLayout from '../../layouts/BlogLayout.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Quiz Dopaminérgico — Zen Caps',
  description: 'Seu cérebro está viciado em dopamina rápida? Quiz gratuito de 10 perguntas baseado em neurociência.',
  url: 'https://zencaps.com.br/blog/quiz-dopamina/',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'BRL' },
  author: { '@type': 'Organization', name: 'Zen Caps', url: 'https://zencaps.com.br' },
}
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://zencaps.com.br/blog/' },
    { '@type': 'ListItem', position: 2, name: 'Quiz Dopamina', item: 'https://zencaps.com.br/blog/quiz-dopamina/' },
  ],
}
---

<BlogLayout
  title="Quiz Dopaminérgico: Seu Cérebro Está Esgotado? | Zen Caps"
  description="Descubra se seus hábitos modernos estão esgotando sua dopamina. Quiz gratuito de 10 perguntas baseado em neurociência."
  canonical="https://zencaps.com.br/blog/quiz-dopamina/"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <style is:inline>
    .qz-wrap{background:linear-gradient(180deg,#1a1040 0%,#2d1b69 40%,#1a1040 100%);min-height:100vh;font-family:'DM Sans',system-ui,sans-serif;overflow-x:hidden}
    .qz-container{max-width:540px;margin:0 auto;padding:0 1.25rem}
    .qz-progress{position:fixed;top:0;left:0;right:0;z-index:100;height:4px;background:rgba(255,255,255,0.08)}
    .qz-progress-fill{height:100%;background:linear-gradient(90deg,#5B6FDE,#8B5CF6);border-radius:0 2px 2px 0;transition:width .6s cubic-bezier(.4,0,.2,1)}
    .qz-topbar{display:flex;align-items:center;justify-content:space-between;padding:1rem 0 .5rem}
    .qz-topbar-back{background:none;border:none;color:rgba(255,255,255,.4);cursor:pointer;padding:8px;border-radius:8px;transition:all .2s;display:flex;align-items:center}
    .qz-topbar-back:hover{color:#fff;background:rgba(255,255,255,.08)}
    .qz-topbar-step{font-family:'Sora',sans-serif;font-size:.72rem;font-weight:700;color:rgba(255,255,255,.35);letter-spacing:.1em;text-transform:uppercase}
    .qz-screen{display:none}.qz-screen.active{display:block;animation:qzSlideIn .4s cubic-bezier(.4,0,.2,1)}
    @keyframes qzSlideIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
    @keyframes qzPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
    @keyframes qzSpin{to{transform:rotate(360deg)}}
    @keyframes qzCountUp{from{opacity:0;transform:scale(.5)}to{opacity:1;transform:scale(1)}}
    .qz-question{font-family:'Sora',sans-serif;font-size:1.25rem;font-weight:800;color:#fff;line-height:1.35;margin:1.5rem 0 1.75rem}
    .qz-option{display:flex;align-items:center;gap:14px;width:100%;padding:16px 20px;margin-bottom:10px;background:rgba(255,255,255,.04);border:2px solid rgba(255,255,255,.08);border-radius:14px;cursor:pointer;transition:all .25s cubic-bezier(.4,0,.2,1);color:rgba(255,255,255,.8);font-size:.95rem;text-align:left;font-family:'DM Sans',system-ui,sans-serif}
    .qz-option:hover{background:rgba(91,111,222,.08);border-color:rgba(91,111,222,.3);transform:translateX(4px)}
    .qz-option.selected{background:rgba(91,111,222,.12);border-color:#8B5CF6;color:#fff;transform:scale(1.02)}
    .qz-option .qz-opt-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;background:rgba(255,255,255,.06);transition:all .25s}
    .qz-option.selected .qz-opt-icon{background:#8B5CF6}
    .qz-option .qz-opt-text{font-weight:500;line-height:1.4}.qz-option.selected .qz-opt-text{font-weight:700}
    .qz-option .qz-opt-check{margin-left:auto;opacity:0;transition:opacity .2s;flex-shrink:0}.qz-option.selected .qz-opt-check{opacity:1}
    .qz-hero{text-align:center;padding:3rem 0 2rem}
    .qz-hero-icon{font-size:4rem;margin-bottom:1rem;animation:qzPulse 3s ease-in-out infinite;display:inline-block}
    .qz-hero h1{font-family:'Sora',sans-serif;font-size:clamp(1.6rem,5vw,2.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 .75rem}
    .qz-hero h1 span{color:#8B5CF6}
    .qz-hero p{font-size:1rem;color:rgba(255,255,255,.5);line-height:1.7;margin:0 0 2rem;max-width:400px;margin-left:auto;margin-right:auto}
    .qz-features{display:flex;flex-direction:column;gap:12px;margin-bottom:2rem;text-align:left;max-width:340px;margin-left:auto;margin-right:auto}
    .qz-feature{display:flex;align-items:center;gap:12px;padding:10px 16px;background:rgba(139,92,246,.06);border:1px solid rgba(139,92,246,.12);border-radius:12px}
    .qz-feature-icon{font-size:1.2rem}.qz-feature-text{font-size:.88rem;color:rgba(255,255,255,.7)}.qz-feature-text strong{color:#fff}
    .qz-cta{width:100%;padding:18px 24px;border:none;border-radius:14px;font-family:'Sora',sans-serif;font-weight:800;font-size:1.05rem;cursor:pointer;transition:all .3s;background:linear-gradient(135deg,#5B6FDE,#8B5CF6);color:#fff;box-shadow:0 8px 32px rgba(91,111,222,.35)}
    .qz-cta:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(91,111,222,.5)}
    .qz-cta-gold{background:linear-gradient(135deg,#C9A84C,#e8c96a);box-shadow:0 8px 32px rgba(201,168,76,.35)}.qz-cta-gold:hover{box-shadow:0 12px 40px rgba(201,168,76,.5)}
    .qz-social{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1.25rem}
    .qz-social-avatars{display:flex}.qz-social-avatars span{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.7rem;border:2px solid #1a1040;margin-left:-8px}.qz-social-avatars span:first-child{margin-left:0}
    .qz-social-text{font-size:.75rem;color:rgba(255,255,255,.4)}.qz-social-text strong{color:rgba(255,255,255,.6)}
    .qz-interstitial{text-align:center;padding:4rem 0}
    .qz-interstitial-icon{font-size:3rem;margin-bottom:1.5rem;display:inline-block}
    .qz-interstitial h2{font-family:'Sora',sans-serif;font-size:1.3rem;font-weight:800;color:#fff;margin:0 0 .75rem;line-height:1.3}
    .qz-interstitial p{font-size:.95rem;color:rgba(255,255,255,.55);line-height:1.7;margin:0;max-width:380px;margin-left:auto;margin-right:auto}
    .qz-stat{display:inline-block;font-family:'Sora',sans-serif;font-size:2.5rem;font-weight:900;background:linear-gradient(135deg,#5B6FDE,#8B5CF6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:.5rem}
    .qz-loading{text-align:center;padding:4rem 0}
    .qz-spinner{width:60px;height:60px;border:3px solid rgba(139,92,246,.15);border-top-color:#8B5CF6;border-radius:50%;animation:qzSpin .8s linear infinite;margin:0 auto 2rem}
    .qz-loading-steps{display:flex;flex-direction:column;gap:14px;max-width:300px;margin:0 auto;text-align:left}
    .qz-loading-step{display:flex;align-items:center;gap:12px;font-size:.88rem;color:rgba(255,255,255,.3);transition:color .5s}
    .qz-loading-step.done{color:rgba(255,255,255,.8)}
    .qz-loading-step .qz-check{width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:.7rem;transition:all .5s;flex-shrink:0}
    .qz-loading-step.done .qz-check{border-color:#8B5CF6;background:#8B5CF6;color:#fff}
    .qz-email-gate{padding:2rem 0}.qz-email-preview{position:relative;margin-bottom:2rem}
    .qz-email-blur{filter:blur(8px);pointer-events:none;opacity:.5}
    .qz-email-overlay{position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center}
    .qz-email-lock{background:rgba(26,16,64,.9);border:1px solid rgba(139,92,246,.2);border-radius:16px;padding:1.5rem 2rem;text-align:center;backdrop-filter:blur(4px)}
    .qz-email-lock p{font-size:.85rem;color:rgba(255,255,255,.6);margin:.5rem 0 0}
    .qz-input{width:100%;padding:16px 20px;border:2px solid rgba(255,255,255,.1);border-radius:12px;font-family:'DM Sans',sans-serif;font-size:.95rem;color:#fff;outline:none;transition:border-color .2s;background:rgba(255,255,255,.04);box-sizing:border-box}
    .qz-input::placeholder{color:rgba(255,255,255,.25)}.qz-input:focus{border-color:#8B5CF6;background:rgba(139,92,246,.04)}.qz-input.error{border-color:#e74c3c}
    .qz-skip{background:none;border:none;color:rgba(255,255,255,.3);font-size:.78rem;cursor:pointer;margin-top:1rem;font-family:'DM Sans',sans-serif;transition:color .2s}.qz-skip:hover{color:rgba(255,255,255,.6)}
    .qz-result{padding:1rem 0 3rem}.qz-score-wrap{text-align:center;margin-bottom:2rem}
    .qz-score-ring{position:relative;width:200px;height:200px;margin:0 auto 1rem}.qz-score-ring svg{transform:rotate(-90deg)}
    .qz-score-val{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
    .qz-score-num{font-family:'Sora',sans-serif;font-size:3rem;font-weight:900;animation:qzCountUp .8s ease-out}
    .qz-score-label{font-size:.75rem;color:rgba(255,255,255,.4)}
    .qz-level-badge{display:inline-flex;align-items:center;gap:6px;padding:8px 20px;border-radius:24px;font-family:'Sora',sans-serif;font-weight:700;font-size:.88rem}
    .qz-level-desc{font-size:.95rem;color:rgba(255,255,255,.6);line-height:1.7;text-align:center;margin:1rem 0 2rem;max-width:440px;margin-left:auto;margin-right:auto}
    .qz-cause{padding:16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:14px;margin-bottom:12px}
    .qz-cause-head{display:flex;align-items:center;gap:10px;margin-bottom:6px}
    .qz-cause-icon{font-size:1.2rem}.qz-cause-name{font-family:'Sora',sans-serif;font-weight:700;font-size:.92rem;color:#fff}
    .qz-cause-tip{font-size:.85rem;color:rgba(255,255,255,.5);line-height:1.6;margin:0}
    .qz-product{background:linear-gradient(135deg,rgba(139,92,246,.1),rgba(139,92,246,.04));border:1px solid rgba(139,92,246,.2);border-radius:18px;padding:2rem;text-align:center;margin:2rem 0}
    .qz-product h3{font-family:'Sora',sans-serif;font-size:1.1rem;font-weight:800;color:#fff;margin:0 0 .5rem}
    .qz-product p{font-size:.88rem;color:rgba(255,255,255,.55);line-height:1.6;margin:0 0 1.25rem}
    .qz-pill{padding:6px 14px;border-radius:20px;font-size:.78rem;font-weight:600;background:rgba(139,92,246,.1);color:#8B5CF6;border:1px solid rgba(139,92,246,.2);display:inline-block;margin:0 4px 8px}
    .qz-seo{padding:3rem 1.5rem;background:#F4F8FC}
    .qz-seo-card{max-width:680px;margin:0 auto 2rem;background:#fff;border-radius:18px;padding:2rem;border:1px solid #e8eef6}
    .qz-seo-card h2{font-family:'Sora',sans-serif;font-size:1.3rem;font-weight:800;color:#0D1B3E;margin:0 0 1rem}
    .qz-seo-card p{font-size:.95rem;color:#3A4A6B;line-height:1.8;margin:0 0 1rem}.qz-seo-card p:last-child{margin-bottom:0}
    .qz-seo-links{max-width:680px;margin:0 auto 2rem;background:#fff;border-radius:18px;padding:2rem;border:1px solid #e8eef6}
    .qz-seo-links h3{font-family:'Sora',sans-serif;font-size:1.1rem;font-weight:700;color:#0D1B3E;margin:0 0 1rem}
    .qz-seo-links a{color:#5B6FDE;text-decoration:none;font-weight:600;font-size:.92rem;display:block;padding:6px 0}.qz-seo-links a:hover{text-decoration:underline}
    @media(max-width:480px){.qz-question{font-size:1.1rem}.qz-score-ring{width:160px;height:160px}.qz-score-num{font-size:2.4rem}.qz-option{padding:14px 16px}}
  </style>

  <div class="qz-wrap" id="quiz-app">
    <div class="qz-progress"><div class="qz-progress-fill" id="qz-progress" style="width:0%"></div></div>
    <div class="qz-container">
      <div class="qz-topbar" id="qz-topbar" style="visibility:hidden;">
        <button type="button" class="qz-topbar-back" onclick="qzPrev()"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg></button>
        <span class="qz-topbar-step" id="qz-step"></span>
        <a href="/blog/" style="font-size:.72rem;color:rgba(255,255,255,.25);text-decoration:none;">Sair</a>
      </div>

      <div class="qz-screen active" id="scr-start">
        <div class="qz-hero">
          <span class="qz-hero-icon">⚡</span>
          <h1>Seu Cérebro Está<br/>Viciado em <span>Dopamina</span>?</h1>
          <p>10 perguntas rápidas para descobrir se seus hábitos modernos estão esgotando seu sistema de recompensa.</p>
          <div class="qz-features">
            <div class="qz-feature"><span class="qz-feature-icon">🧬</span><span class="qz-feature-text">Perfil: <strong>Equilibrado, Estimulado ou Esgotado</strong></span></div>
            <div class="qz-feature"><span class="qz-feature-icon">🔗</span><span class="qz-feature-text">Conexão <strong>dopamina → sono → ansiedade</strong></span></div>
            <div class="qz-feature"><span class="qz-feature-icon">📋</span><span class="qz-feature-text"><strong>Protocolo de reset</strong> dopaminérgico</span></div>
          </div>
          <button type="button" class="qz-cta" onclick="qzStart()">Descobrir meu perfil dopaminérgico</button>
          <div class="qz-social">
            <div class="qz-social-avatars"><span style="background:#8B5CF6">👩</span><span style="background:#5B6FDE">👨</span><span style="background:#C9A84C">👩</span><span style="background:#0fa36b">👨</span></div>
            <span class="qz-social-text"><strong>1.923 pessoas</strong> fizeram este quiz</span>
          </div>
        </div>
      </div>

      <div class="qz-screen" id="scr-question"><h2 class="qz-question" id="qz-question"></h2><div id="qz-options"></div></div>
      <div class="qz-screen" id="scr-inter1"><div class="qz-interstitial"><span class="qz-interstitial-icon">🧪</span><h2>Analisando seus padrões neurais...</h2><p>Já detectamos tendências importantes. Mais 6 perguntas para mapear seu perfil completo.</p></div></div>
      <div class="qz-screen" id="scr-inter2"><div class="qz-interstitial"><div class="qz-stat">73%</div><h2>dos brasileiros adultos apresentam sinais de sobrecarga dopaminérgica</h2><p>Mais 3 perguntas para finalizar seu perfil.</p></div></div>

      <div class="qz-screen" id="scr-loading">
        <div class="qz-loading">
          <div class="qz-spinner"></div>
          <h2 style="font-family:'Sora',sans-serif;font-size:1.2rem;font-weight:800;color:#fff;margin:0 0 2rem;">Mapeando seu perfil dopaminérgico...</h2>
          <div class="qz-loading-steps">
            <div class="qz-loading-step" id="load-1"><span class="qz-check">✓</span> Analisando padrões de recompensa</div>
            <div class="qz-loading-step" id="load-2"><span class="qz-check">✓</span> Calculando nível de sensibilização</div>
            <div class="qz-loading-step" id="load-3"><span class="qz-check">✓</span> Gerando protocolo personalizado</div>
          </div>
        </div>
      </div>

      <div class="qz-screen" id="scr-email">
        <div class="qz-email-gate">
          <div style="text-align:center;margin-bottom:2rem;">
            <span style="font-size:2.5rem;display:inline-block;margin-bottom:.75rem;">🧬</span>
            <h2 style="font-family:'Sora',sans-serif;font-size:1.25rem;font-weight:800;color:#fff;margin:0 0 .5rem;">Seu perfil está pronto!</h2>
            <p style="font-size:.9rem;color:rgba(255,255,255,.5);line-height:1.6;margin:0;">Para onde enviamos seu protocolo de reset?</p>
          </div>
          <div class="qz-email-preview"><div class="qz-email-blur" id="qz-blur-preview"></div><div class="qz-email-overlay"><div class="qz-email-lock"><span style="font-size:1.5rem;">🔒</span><p>Informe seu email para desbloquear</p></div></div></div>
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:1rem;">
            <input type="text" id="qz-name" class="qz-input" placeholder="Seu primeiro nome" />
            <input type="email" id="qz-email" class="qz-input" placeholder="Seu melhor email" />
          </div>
          <button type="button" class="qz-cta" onclick="qzSubmitEmail()">Ver meu perfil completo</button>
          <div style="text-align:center;"><button type="button" class="qz-skip" onclick="qzSkipEmail()">Pular e ver resultado resumido</button></div>
          <p style="font-size:.68rem;color:rgba(255,255,255,.2);text-align:center;margin:1rem 0 0;line-height:1.5;">Seus dados estão seguros. Sem spam. Cancele quando quiser.</p>
        </div>
      </div>

      <div class="qz-screen" id="scr-result"><div class="qz-result" id="qz-result-content"></div></div>
    </div>
  </div>

  <div class="qz-seo">
    <div class="qz-seo-card">
      <h2>O que é o esgotamento dopaminérgico?</h2>
      <p>A dopamina é o neurotransmissor da <strong>motivação, foco e prazer</strong>. Quando você consome estímulos rápidos em excesso — redes sociais, açúcar, notificações — o cérebro reduz os receptores de dopamina para se proteger.</p>
      <p>Isso afeta diretamente o sono (a dopamina regula o ritmo circadiano), a ansiedade (menos dopamina = mais cortisol) e a produtividade. O quiz identifica em que estágio você está.</p>
    </div>
    <div class="qz-seo-links">
      <h3>Artigos relacionados</h3>
      <a href="/blog/celular-antes-de-dormir-prejudica-sono/">Como o celular prejudica seu sono</a>
      <a href="/blog/como-controlar-ansiedade-naturalmente/">Como controlar ansiedade naturalmente</a>
      <a href="/blog/triptofano-para-que-serve-beneficios/">Triptofano: para que serve e benefícios</a>
      <a href="/blog/burnout-como-identificar-recuperar/">Burnout: como identificar e recuperar</a>
    </div>
    <div style="text-align:center;padding-bottom:3rem;"><a href="/blog/" style="font-weight:700;color:#5B6FDE;text-decoration:none;font-size:.95rem;">← Voltar para o blog</a></div>
  </div>

  <script is:inline>
    var QZ = {
      questions: [
        { q: 'Qual é a primeira coisa que você faz ao acordar?', opts: [
          { text: 'Alongar, tomar água ou meditar', icon: '🧘', score: 3 },
          { text: 'Tomar café e me preparar', icon: '☕', score: 2 },
          { text: 'Checar celular rapidamente', icon: '📱', score: 1 },
          { text: 'Ficar scrollando redes sociais na cama', icon: '📲', score: 0 },
        ], cat: 'rotina' },
        { q: 'Quanto tempo por dia você passa em redes sociais?', opts: [
          { text: 'Menos de 30 minutos', icon: '⏱️', score: 3 },
          { text: '30 minutos a 1 hora', icon: '🕐', score: 2 },
          { text: '1 a 3 horas', icon: '📵', score: 1 },
          { text: 'Mais de 3 horas', icon: '🤯', score: 0 },
        ], cat: 'telas' },
        { q: 'Você consegue se concentrar por mais de 25 min sem distração?', opts: [
          { text: 'Sim, com facilidade', icon: '🎯', score: 3 },
          { text: 'Na maioria das vezes', icon: '👍', score: 2 },
          { text: 'Tenho dificuldade frequente', icon: '😵', score: 1 },
          { text: 'Quase nunca — preciso de estímulo constante', icon: '🌀', score: 0 },
        ], cat: 'foco' },
        { q: 'Como você se sente quando não tem nada para fazer?', opts: [
          { text: 'Tranquilo — aproveito o momento', icon: '😌', score: 3 },
          { text: 'Consigo relaxar, mas prefiro estar ocupado', icon: '🤔', score: 2 },
          { text: 'Fico inquieto e procuro algo', icon: '😬', score: 1 },
          { text: 'Sinto ansiedade ou tédio insuportável', icon: '😰', score: 0 },
        ], cat: 'tedio' },
        { q: 'Quando está estressado, o que você faz?', opts: [
          { text: 'Exercício, meditação ou conversa', icon: '🏃', score: 3 },
          { text: 'Assisto algo ou ouço música', icon: '🎧', score: 2 },
          { text: 'Como doces/junk food ou bebo', icon: '🍫', score: 1 },
          { text: 'Scrollo redes ou compro online', icon: '🛒', score: 0 },
        ], cat: 'coping' },
        { q: 'Você procrastina tarefas importantes?', opts: [
          { text: 'Raramente — faço o que precisa ser feito', icon: '✅', score: 3 },
          { text: 'Às vezes, mas consigo me organizar', icon: '📋', score: 2 },
          { text: 'Frequentemente — último minuto', icon: '⏰', score: 1 },
          { text: 'Sempre — só sob pressão extrema', icon: '🔥', score: 0 },
        ], cat: 'procrastinacao' },
        { q: 'Sua motivação no dia a dia está:', opts: [
          { text: 'Alta — tenho energia e propósito', icon: '🚀', score: 3 },
          { text: 'Normal — dias bons e ruins', icon: '⚖️', score: 2 },
          { text: 'Baixa — preciso me forçar', icon: '😮‍💨', score: 1 },
          { text: 'Muito baixa — nada vale o esforço', icon: '😶', score: 0 },
        ], cat: 'motivacao' },
        { q: 'Você sente sono de dia mas não consegue dormir à noite?', opts: [
          { text: 'Não — durmo bem e fico alerta', icon: '😊', score: 3 },
          { text: 'Às vezes sono à tarde', icon: '🥱', score: 2 },
          { text: 'Cochilo de dia, insônia à noite', icon: '😩', score: 1 },
          { text: 'Padrão totalmente invertido', icon: '🦇', score: 0 },
        ], cat: 'circadiano' },
        { q: 'Você precisa de cafeína para funcionar?', opts: [
          { text: 'Não — tomo por prazer', icon: '☕', score: 3 },
          { text: '1 café pela manhã resolve', icon: '🌅', score: 2 },
          { text: '2-3 cafés, senão não rendo', icon: '💊', score: 1 },
          { text: '4+ cafés ou energéticos', icon: '⚡', score: 0 },
        ], cat: 'cafeina' },
        { q: 'Hobbies que antes te davam prazer ainda funcionam?', opts: [
          { text: 'Sim — mesmo prazer de sempre', icon: '😄', score: 3 },
          { text: 'Maioria sim, algumas perdi interesse', icon: '🤷', score: 2 },
          { text: 'Poucas coisas ainda me dão prazer', icon: '😕', score: 1 },
          { text: 'Quase nada me anima mais', icon: '😞', score: 0 },
        ], cat: 'anedonia' },
      ],
      interstitials: { 4: 'scr-inter1', 7: 'scr-inter2' },
      current: 0, answers: [], hasEmail: false
    };
    QZ.answers = new Array(QZ.questions.length).fill(-1);

    var causeData = {
      rotina:        { name: 'Rotina matinal reativa', icon: '📱', tip: 'Começar o dia com celular inunda o cérebro de dopamina antes de produzir naturalmente.' },
      telas:         { name: 'Excesso de tempo de tela', icon: '📲', tip: 'Redes sociais liberam micro-doses de dopamina a cada scroll. O cérebro se adapta e precisa de mais.' },
      foco:          { name: 'Dificuldade de concentração', icon: '🌀', tip: 'Quando acostumado com estímulos rápidos, tarefas com atenção sustentada parecem insuportáveis.' },
      tedio:         { name: 'Intolerância ao tédio', icon: '😰', tip: 'A incapacidade de ficar sem estímulo é um dos sinais mais claros de dessensibilização dopaminérgica.' },
      coping:        { name: 'Mecanismos de escape', icon: '🍫', tip: 'Usar comida, compras ou redes sociais como válvula mantém o ciclo de dopamina rápida.' },
      procrastinacao:{ name: 'Procrastinação crônica', icon: '⏰', tip: 'Dopamina esgotada = cérebro busca recompensas imediatas em vez de projetos de longo prazo.' },
      motivacao:     { name: 'Motivação em queda', icon: '😶', tip: 'Dopamina baixa = tudo parece difícil demais. Não é preguiça — é neurociência.' },
      circadiano:    { name: 'Ritmo circadiano invertido', icon: '🦇', tip: 'A dopamina regula o ciclo sono-vigília. Desequilíbrio causa sono de dia e agitação à noite.' },
      cafeina:       { name: 'Dependência de cafeína', icon: '⚡', tip: 'Cafeína em excesso mascara a fadiga real e mantém o ciclo de esgotamento.' },
      anedonia:      { name: 'Anedonia (perda de prazer)', icon: '😞', tip: 'Quando atividades normais não dão prazer, os receptores D2 estão dessensibilizados.' },
    };

    function qzShowScreen(id) { document.querySelectorAll('.qz-screen').forEach(function(el) { el.classList.remove('active'); }); document.getElementById(id).classList.add('active'); window.scrollTo({top:0,behavior:'smooth'}); }
    function qzUpdateProgress() { var pct = Math.round(((QZ.current+1)/QZ.questions.length)*100); document.getElementById('qz-progress').style.width = pct+'%'; document.getElementById('qz-step').textContent = (QZ.current+1)+' de '+QZ.questions.length; }

    function qzStart() { document.getElementById('qz-topbar').style.visibility='visible'; QZ.current=0; qzUpdateProgress(); qzRenderQuestion(); qzShowScreen('scr-question'); }

    function qzRenderQuestion() {
      var q = QZ.questions[QZ.current];
      document.getElementById('qz-question').textContent = q.q; qzUpdateProgress();
      var wrap = document.getElementById('qz-options'); wrap.innerHTML = '';
      q.opts.forEach(function(opt, i) {
        var btn = document.createElement('button'); btn.type='button';
        btn.className = 'qz-option' + (QZ.answers[QZ.current]===i?' selected':'');
        var ic = document.createElement('span'); ic.className='qz-opt-icon'; ic.textContent=opt.icon;
        var tx = document.createElement('span'); tx.className='qz-opt-text'; tx.textContent=opt.text;
        var ck = document.createElement('span'); ck.className='qz-opt-check'; ck.textContent='✓';
        btn.appendChild(ic); btn.appendChild(tx); btn.appendChild(ck);
        btn.addEventListener('click', function() { qzSelect(i); }); wrap.appendChild(btn);
      });
    }

    function qzSelect(i) { QZ.answers[QZ.current]=i; document.querySelectorAll('.qz-option').forEach(function(el,idx){el.classList.toggle('selected',idx===i);}); setTimeout(function(){qzNext();},400); }

    function qzNext() {
      if (QZ.current < QZ.questions.length-1) { QZ.current++;
        if (QZ.interstitials[QZ.current]) { qzShowScreen(QZ.interstitials[QZ.current]); setTimeout(function(){ qzRenderQuestion(); qzShowScreen('scr-question'); },2200); }
        else { qzRenderQuestion(); qzShowScreen('scr-question'); }
      } else { qzShowLoading(); }
    }
    function qzPrev() { if (QZ.current>0) { QZ.current--; qzUpdateProgress(); qzRenderQuestion(); qzShowScreen('scr-question'); } else { document.getElementById('qz-topbar').style.visibility='hidden'; qzShowScreen('scr-start'); document.getElementById('qz-progress').style.width='0%'; } }

    function qzShowLoading() { document.getElementById('qz-progress').style.width='100%'; qzShowScreen('scr-loading'); ['load-1','load-2','load-3'].forEach(function(id,idx){ setTimeout(function(){ document.getElementById(id).classList.add('done'); },800*(idx+1)); }); setTimeout(function(){ qzShowEmailGate(); },3200); }

    function qzCalcScore() { var t=0; for(var i=0;i<QZ.answers.length;i++) t+=QZ.questions[i].opts[QZ.answers[i]].score; return Math.round((t/(QZ.questions.length*3))*100); }

    function qzGetLevel(s) {
      if (s>=75) return {label:'Equilibrado',color:'#0fa36b',bg:'rgba(15,163,107,.12)',border:'rgba(15,163,107,.3)',emoji:'🟢',desc:'Seu sistema dopaminérgico está saudável. Você tem bom controle sobre estímulos e mantém fontes naturais de prazer.'};
      if (s>=45) return {label:'Estimulado',color:'#C9A84C',bg:'rgba(201,168,76,.12)',border:'rgba(201,168,76,.3)',emoji:'🟡',desc:'Seus receptores de dopamina estão parcialmente dessensibilizados. Alguns hábitos puxam seu cérebro para o ciclo de recompensa rápida.'};
      return {label:'Esgotado',color:'#e74c3c',bg:'rgba(231,76,60,.12)',border:'rgba(231,76,60,.3)',emoji:'🔴',desc:'Seu sistema de recompensa está comprometido. A busca por estímulos rápidos está afetando foco, sono e motivação.'};
    }

    function qzGetCauses() { var cs={}; for(var i=0;i<QZ.answers.length;i++) cs[QZ.questions[i].cat]=QZ.questions[i].opts[QZ.answers[i]].score; var s=Object.entries(cs).sort(function(a,b){return a[1]-b[1]}); var w=s.filter(function(x){return x[1]<=1}).slice(0,3); return w.length?w:s.slice(0,3); }

    function qzShowEmailGate() {
      var sc=qzCalcScore(),lv=qzGetLevel(sc),r=60,circ=2*Math.PI*r,off=circ-(sc/100)*circ;
      document.getElementById('qz-blur-preview').innerHTML='<div style="text-align:center;padding:2rem 1rem;"><svg width="140" height="140" style="transform:rotate(-90deg)"><circle cx="70" cy="70" r="'+r+'" stroke="rgba(255,255,255,.08)" stroke-width="8" fill="none"/><circle cx="70" cy="70" r="'+r+'" stroke="'+lv.color+'" stroke-width="8" fill="none" stroke-dasharray="'+circ+'" stroke-dashoffset="'+off+'" stroke-linecap="round"/></svg><div style="font-family:Sora,sans-serif;font-size:1.5rem;font-weight:900;color:'+lv.color+';margin-top:-90px;position:relative;">'+sc+'</div><div style="font-size:.7rem;color:rgba(255,255,255,.3);margin-top:55px;">de 100</div><div style="margin-top:1rem;display:inline-block;padding:6px 14px;border-radius:16px;background:'+lv.bg+';border:1px solid '+lv.border+';font-size:.8rem;font-weight:700;color:'+lv.color+';">'+lv.emoji+' '+lv.label+'</div></div>';
      qzShowScreen('scr-email');
    }

    function qzSubmitEmail() {
      var n=document.getElementById('qz-name').value.trim(),e=document.getElementById('qz-email').value.trim();
      if(!e||!e.includes('@')||!e.includes('.')){document.getElementById('qz-email').classList.add('error');return;}
      document.getElementById('qz-email').classList.remove('error'); QZ.hasEmail=true;
      var btn=document.getElementById('qz-btn-email');
      if(btn){btn.disabled=true;btn.textContent='Salvando...';}
      fetch('/api/quiz-lead/',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:n,email:e,quiz:'dopamina',score:qzCalcScore()})})
      .then(function(r){return r.json();})
      .then(function(){qzShowResult(true,n);})
      .catch(function(){qzShowResult(true,n);});
    }
    function qzSkipEmail(){qzShowResult(false,'');}

    function qzShowResult(full,userName) {
      var sc=qzCalcScore(),lv=qzGetLevel(sc),causes=qzGetCauses(),r=88,circ=2*Math.PI*r,off=circ-(sc/100)*circ;
      var h='';
      if(userName){h+='<p style="text-align:center;font-size:.85rem;color:rgba(255,255,255,.4);margin:0 0 .25rem;">Perfil de</p><p style="text-align:center;font-family:Sora,sans-serif;font-size:1.1rem;font-weight:700;color:#fff;margin:0 0 1.5rem;">'+userName+'</p>';}
      h+='<div class="qz-score-wrap"><div class="qz-score-ring"><svg width="200" height="200"><circle cx="100" cy="100" r="'+r+'" stroke="rgba(255,255,255,.06)" stroke-width="10" fill="none"/><circle cx="100" cy="100" r="'+r+'" stroke="'+lv.color+'" stroke-width="10" fill="none" stroke-dasharray="'+circ+'" stroke-dashoffset="'+off+'" stroke-linecap="round" style="transition:stroke-dashoffset 1.5s ease-out;"/></svg><div class="qz-score-val"><div class="qz-score-num" style="color:'+lv.color+';">'+sc+'</div><div class="qz-score-label">de 100</div></div></div><span class="qz-level-badge" style="background:'+lv.bg+';border:1px solid '+lv.border+';color:'+lv.color+';">'+lv.emoji+' '+lv.label+'</span></div>';
      h+='<p class="qz-level-desc">'+lv.desc+'</p>';
      h+='<h3 style="font-family:Sora,sans-serif;font-size:1rem;font-weight:700;color:#fff;margin:0 0 1rem;">'+(full?'🔍 Padrões identificados:':'Pontos de atenção:')+'</h3>';
      causes.forEach(function(item){var c=causeData[item[0]];h+='<div class="qz-cause"><div class="qz-cause-head"><span class="qz-cause-icon">'+c.icon+'</span><span class="qz-cause-name">'+c.name+'</span></div>'+(full?'<p class="qz-cause-tip">'+c.tip+'</p>':'')+'</div>';});

      if(full){
        h+='<div style="margin:1.5rem 0;padding:1.25rem;background:rgba(139,92,246,.08);border:1px solid rgba(139,92,246,.15);border-radius:14px;"><h4 style="font-family:Sora,sans-serif;font-size:.95rem;font-weight:700;color:#8B5CF6;margin:0 0 .5rem;">🔄 Dopamina → Sono → Ansiedade</h4><p style="font-size:.85rem;color:rgba(255,255,255,.55);line-height:1.6;margin:0;">Dopamina esgotada → serotonina cai → melatonina reduz → sono piora → cortisol sobe → ansiedade aumenta. O triptofano quebra esse ciclo: é precursor da serotonina.</p></div>';
        h+='<div class="qz-product"><p style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#8B5CF6;margin:0 0 .5rem;">Recomendação para seu perfil</p><h3>Resete seu sistema de recompensa</h3><p>Zen Caps combina triptofano (restaura serotonina), magnésio (protege receptores) e vitamina B6 (cofator na produção de dopamina saudável).</p><div style="margin-bottom:1.25rem;"><span class="qz-pill">Triptofano</span><span class="qz-pill">Magnésio</span><span class="qz-pill">Vitamina B6</span><span class="qz-pill">Melatonina</span></div><a href="https://zencaps.com.br" target="_blank" rel="noopener" class="qz-cta qz-cta-gold" style="display:inline-block;width:auto;padding:14px 32px;text-decoration:none;font-size:.95rem;">Conhecer Zen Caps →</a></div>';
      } else {
        h+='<div style="margin-top:2rem;padding:1.25rem;background:rgba(139,92,246,.06);border:1px solid rgba(139,92,246,.15);border-radius:14px;text-align:center;"><p style="font-size:.88rem;color:rgba(255,255,255,.6);margin:0 0 .75rem;">Quer o protocolo de reset dopaminérgico?</p><button type="button" class="qz-cta" onclick="qzShowScreen(\'scr-email\')" style="font-size:.88rem;padding:12px 24px;">Desbloquear resultado completo</button></div>';
      }
      h+='<div style="display:flex;gap:12px;justify-content:center;margin-top:2rem;flex-wrap:wrap;"><button type="button" onclick="qzReset()" style="background:none;border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);padding:10px 20px;border-radius:10px;cursor:pointer;font-family:DM Sans,sans-serif;font-size:.85rem;">Refazer quiz</button><a href="/blog/" style="display:inline-flex;align-items:center;gap:6px;background:none;border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.5);padding:10px 20px;border-radius:10px;text-decoration:none;font-size:.85rem;">← Voltar ao blog</a></div>';
      document.getElementById('qz-result-content').innerHTML=h; qzShowScreen('scr-result');
    }

    function qzReset(){QZ.current=0;QZ.answers=new Array(QZ.questions.length).fill(-1);QZ.hasEmail=false;document.getElementById('qz-progress').style.width='0%';document.getElementById('qz-topbar').style.visibility='hidden';['load-1','load-2','load-3'].forEach(function(id){document.getElementById(id).classList.remove('done');});qzShowScreen('scr-start');}
  </script>
