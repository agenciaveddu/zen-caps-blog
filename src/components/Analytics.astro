---
// Analytics.astro — Sistema de rastreamento GA4 completo
// Propriedade: Zen Caps | ID: G-1KQL3SBYNB
// ─────────────────────────────────────────────────────
// EVENTOS DISPARADOS:
//   Engajamento → scroll_50 | scroll_90 | time_on_page_30s | time_on_page_60s
//   Conversão   → click_cta | click_checkout | click_whatsapp
//   Saída       → outbound_click (destination_type: checkout | whatsapp | affiliate | external)
//
// Inclua SOMENTE nos layouts base (ArticleLayout + BlogLayout). Sem duplicação.
---

<!-- GA4: script de medição (async — zero impacto em performance) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-1KQL3SBYNB"></script>

<!-- GA4: inicialização + sistema de rastreamento -->
<script is:inline>
(function () {
  'use strict';

  // ── Inicialização GA4 ──────────────────────────────────────────────────────
  window.dataLayer = window.dataLayer || [];
  function gtag() { dataLayer.push(arguments); }
  window.gtag = gtag; // expõe globalmente para debug
  gtag('js', new Date());
  gtag('config', 'G-1KQL3SBYNB', {
    page_path: window.location.pathname,
    send_page_view: true,
  });

  // ── Helper: parâmetros de página (enviados em TODOS os eventos) ────────────
  function pageCtx() {
    return {
      page_path:  window.location.pathname,
      page_title: document.title.substring(0, 150),
    };
  }

  // ── Helper: classificação de destino de links ──────────────────────────────
  function classifyLink(href) {
    if (!href) return null;
    if (href.includes('wa.me') || href.includes('whatsapp.com')) return 'whatsapp';
    if (
      (href.includes('zencaps.com.br') && !href.includes('/blog')) ||
      href.includes('buygoods.com') ||
      href.includes('cartpanda.com') ||
      href.includes('/checkout') ||
      href.includes('pay.')
    ) return 'checkout';
    if (
      href.includes('hotmart.com') ||
      href.includes('kiwify.com') ||
      href.includes('eduzz.com') ||
      href.includes('monetizze.com')
    ) return 'affiliate';
    if (href.startsWith('http') && !href.includes('zencaps.com.br')) return 'external';
    return null; // link interno — ignorar
  }

  // ── Helper: localização do CTA clicado ────────────────────────────────────
  function ctaLocation(el) {
    return (
      el.getAttribute('data-cta') ||
      el.closest('[data-cta]')?.getAttribute('data-cta') ||
      el.closest('[data-section]')?.getAttribute('data-section') ||
      'desconhecido'
    );
  }

  // ── Guarda de inicialização (evita duplicação se componente for carregado 2x) ──
  if (window.__zenAnalyticsLoaded) return;
  window.__zenAnalyticsLoaded = true;

  // ══════════════════════════════════════════════════════════════════════════
  // Registra tudo após DOM pronto
  // ══════════════════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function () {

    // ── 1. SCROLL DEPTH ───────────────────────────────────────────────────────
    var scrollFired = { s50: false, s90: false };

    window.addEventListener('scroll', function () {
      var scrolled = window.scrollY + window.innerHeight;
      var total    = document.documentElement.scrollHeight;
      if (total <= 0) return;
      var pct = Math.round((scrolled / total) * 100);

      if (!scrollFired.s50 && pct >= 50) {
        scrollFired.s50 = true;
        gtag('event', 'scroll_50', Object.assign(pageCtx(), {
          event_category: 'Engajamento',
          event_label: '50% do artigo lido',
        }));
      }
      if (!scrollFired.s90 && pct >= 90) {
        scrollFired.s90 = true;
        gtag('event', 'scroll_90', Object.assign(pageCtx(), {
          event_category: 'Engajamento',
          event_label: '90% do artigo lido',
        }));
      }
    }, { passive: true });

    // ── 2. TEMPO NA PÁGINA ────────────────────────────────────────────────────
    var t30, t60;

    t30 = setTimeout(function () {
      gtag('event', 'time_on_page_30s', Object.assign(pageCtx(), {
        event_category: 'Engajamento',
        event_label: '30 segundos na página',
      }));
    }, 30000);

    t60 = setTimeout(function () {
      gtag('event', 'time_on_page_60s', Object.assign(pageCtx(), {
        event_category: 'Engajamento',
        event_label: '60 segundos na página',
      }));
    }, 60000);

    // Cancela timers se o usuário sair da aba (evita falsos positivos)
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        clearTimeout(t30);
        clearTimeout(t60);
      }
    });

    // ── 3. HANDLER ÚNICO DE CLIQUES (event delegation) ───────────────────────
    // Um único listener na raiz — leve, sem duplicação, sem memory leak
    document.addEventListener('click', function (e) {
      var link = e.target.closest('a[href]');
      if (!link) return;

      var href = (link.getAttribute('href') || '').trim();
      var dest = classifyLink(href);
      if (!dest) return; // link interno → ignorar

      var isCta = (
        link.classList.contains('zen-btn-gold') ||
        link.hasAttribute('data-cta') ||
        !!link.closest('[data-cta]')
      );
      var loc     = ctaLocation(link);
      var btnText = (link.innerText || link.textContent || '').trim().substring(0, 100);
      var ctx     = pageCtx();

      // ─── WHATSAPP ──────────────────────────────────────────────────────────
      if (dest === 'whatsapp') {
        gtag('event', 'click_whatsapp', Object.assign({}, ctx, {
          event_category: 'Conversão',
          event_label:    'WhatsApp',
          cta_location:   loc,
          outbound:       true,
          destination_type: 'whatsapp',
        }));
        gtag('event', 'outbound_click', Object.assign({}, ctx, {
          event_category:   'Saída',
          event_label:      href,
          link_url:         href,
          destination_type: 'whatsapp',
        }));
        return;
      }

      // ─── CHECKOUT / SITE DE VENDAS ─────────────────────────────────────────
      if (dest === 'checkout') {
        // Evento de conversão principal
        gtag('event', 'click_checkout', Object.assign({}, ctx, {
          event_category:   'Conversão',
          event_label:      href,
          cta_text:         btnText,
          cta_location:     loc,
          outbound:         true,
          destination_type: 'checkout',
        }));
        // Evento de CTA (para análise de qual botão performou melhor)
        if (isCta) {
          gtag('event', 'click_cta', Object.assign({}, ctx, {
            event_category: 'CTA',
            event_label:    btnText,
            cta_text:       btnText,
            cta_location:   loc,
          }));
        }
        gtag('event', 'outbound_click', Object.assign({}, ctx, {
          event_category:   'Saída',
          event_label:      href,
          link_url:         href,
          destination_type: 'checkout',
        }));
        return;
      }

      // ─── LINKS DE AFILIADO ─────────────────────────────────────────────────
      if (dest === 'affiliate') {
        gtag('event', 'outbound_click', Object.assign({}, ctx, {
          event_category:   'Saída',
          event_label:      href,
          link_url:         href,
          destination_type: 'affiliate',
        }));
        return;
      }

      // ─── OUTROS LINKS EXTERNOS ─────────────────────────────────────────────
      if (dest === 'external') {
        gtag('event', 'outbound_click', Object.assign({}, ctx, {
          event_category:   'Saída',
          event_label:      href,
          link_url:         href,
          destination_type: 'external',
        }));
      }

    }); // fim click handler

  }); // fim DOMContentLoaded

})(); // fim IIFE
</script>
