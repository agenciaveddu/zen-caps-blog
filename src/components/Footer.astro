---
const year = new Date().getFullYear()

const blogLinks = [
  { label: 'Todos os artigos',  href: '/blog' },
  { label: 'Buscar artigos',    href: '/blog/busca' },
  { label: 'Sobre a equipe',    href: '/blog/sobre' },
  { label: 'Contato',           href: '/blog/contato' },
]

const categories = [
  { label: 'Sono & Insônia',        href: '/blog/categoria/sono' },
  { label: 'Ansiedade & Estresse',  href: '/blog/categoria/ansiedade' },
  { label: 'Ingredientes & Ciência',href: '/blog/categoria/ingredientes' },
  { label: 'Hábitos Saudáveis',     href: '/blog/categoria/habitos' },
]

const legalLinks = [
  { label: 'Política de Privacidade', href: 'https://zencaps.com.br/politica-de-privacidade' },
  { label: 'Termos de Uso',           href: 'https://zencaps.com.br/termos-de-uso' },
  { label: 'Contato',                 href: '/blog/contato' },
  { label: 'Site Oficial',            href: 'https://zencaps.com.br' },
]

const linkStyle = "font-size: 0.875rem; color: #6B7A9A; text-decoration: none; font-family: 'DM Sans', system-ui, sans-serif; transition: color 0.15s;"
const headingStyle = "font-family: 'Sora', system-ui, sans-serif; font-weight: 700; color: rgba(255,255,255,0.9); margin-bottom: 14px; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em;"
---

<footer style="background: #0D1B3E; border-top: 1px solid rgba(29,184,232,0.15); margin-top: 4rem;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">

    <!-- 4 colunas -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 2.5rem; margin-bottom: 2.5rem;">

      <!-- 1. Marca + Social -->
      <div>
        <a href="/blog" style="text-decoration: none; display: flex; align-items: baseline; gap: 4px; line-height: 1; margin-bottom: 12px;">
          <span style="font-family: 'Sora', system-ui, sans-serif; font-weight: 900; font-size: 1.4rem; color: #1DB8E8; letter-spacing: -0.02em;">ZEN</span>
          <span style="font-family: 'DM Sans', system-ui, sans-serif; font-style: italic; font-weight: 600; color: #ffffff; font-size: 1rem;">caps</span>
          <span style="color: #6B7A9A; font-size: 0.65rem; margin-left: 8px; letter-spacing: 0.12em; text-transform: uppercase; font-family: 'DM Sans', system-ui, sans-serif; align-self: center;">Blog</span>
        </a>
        <p style="font-size: 0.85rem; color: #6B7A9A; line-height: 1.7; margin-bottom: 1rem;">
          Conteúdo baseado em ciência sobre sono, ansiedade e bem-estar natural.
        </p>
        <!-- Redes sociais -->
        <div style="display: flex; gap: 10px; margin-bottom: 16px;">
          {[
            {
              href: 'https://www.instagram.com/zencapsoficial/',
              label: 'Instagram Zen Caps',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`,
            },
            {
              href: 'https://www.facebook.com/zencapsoficial',
              label: 'Facebook Zen Caps',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>`,
            },
            {
              href: 'https://wa.me/5511988204942',
              label: 'WhatsApp Zen Caps',
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
            },
          ].map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:8px;background:rgba(29,184,232,0.08);border:1px solid rgba(29,184,232,0.2);color:#6B7A9A;text-decoration:none;transition:all 0.2s;"
              onmouseover="this.style.background='rgba(29,184,232,0.18)';this.style.borderColor='#1DB8E8';this.style.color='#1DB8E8'"
              onmouseout="this.style.background='rgba(29,184,232,0.08)';this.style.borderColor='rgba(29,184,232,0.2)';this.style.color='#6B7A9A'"
            >
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
        <div style="height:2px;background:linear-gradient(90deg,#1DB8E8 0%,transparent 100%);border-radius:4px;width:60px;opacity:0.6;"></div>
      </div>

      <!-- 2. Blog -->
      <div>
        <h3 style={headingStyle}>Blog</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:9px;">
          {blogLinks.map(l => (
            <li>
              <a
                href={l.href}
                style={linkStyle}
                onmouseover="this.style.color='#1DB8E8'"
                onmouseout="this.style.color='#6B7A9A'"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- 3. Categorias -->
      <div>
        <h3 style={headingStyle}>Categorias</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:9px;">
          {categories.map(l => (
            <li>
              <a
                href={l.href}
                style={linkStyle}
                onmouseover="this.style.color='#1DB8E8'"
                onmouseout="this.style.color='#6B7A9A'"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- 4. Produto -->
      <div>
        <h3 style={headingStyle}>O Produto</h3>
        <p style="font-size:0.85rem;color:#6B7A9A;margin-bottom:18px;line-height:1.7;">
          Zen Caps combina melatonina, triptofano, magnésio e vitamina B6 para você dormir melhor e controlar a ansiedade. Aprovado pela ANVISA.
        </p>
        <a
          href="https://zencaps.com.br"
          target="_blank"
          rel="noopener noreferrer"
          class="zen-btn-gold"
          style="font-size:0.85rem;display:inline-block;"
        >
          Conhecer o Zen Caps &rarr;
        </a>
      </div>

    </div>

    <!-- Disclaimer médico -->
    <div style="border-top:1px solid rgba(29,184,232,0.1);padding-top:20px;margin-bottom:18px;">
      <p style="font-size:0.72rem;color:rgba(107,122,154,0.7);line-height:1.6;text-align:center;max-width:680px;margin:0 auto;">
        ⚠️ O conteúdo deste blog tem finalidade informativa e educacional. Não substitui diagnóstico, tratamento ou aconselhamento médico. Consulte sempre um profissional de saúde antes de iniciar qualquer suplementação.
      </p>
    </div>

    <!-- Bottom bar -->
    <div style="border-top:1px solid rgba(29,184,232,0.08);padding-top:18px;display:flex;flex-direction:column;gap:8px;align-items:center;text-align:center;">
      <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center;">
        {legalLinks.map(l => (
          <a
            href={l.href}
            target={l.href.startsWith('http') ? '_blank' : undefined}
            rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            style="font-size:0.72rem;color:#6B7A9A;text-decoration:none;transition:color 0.15s;"
            onmouseover="this.style.color='#1DB8E8'"
            onmouseout="this.style.color='#6B7A9A'"
          >
            {l.label}
          </a>
        ))}
      </div>
      <p style="font-size:0.72rem;color:rgba(107,122,154,0.5);">
        &copy; {year} Zen Caps. Todos os direitos reservados. CNPJ: consulte o <a href="https://zencaps.com.br" style="color:inherit;">site oficial</a>.
      </p>
    </div>

  </div>
</footer>
