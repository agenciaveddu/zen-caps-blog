---
const navLinks = [
  { label: 'Sono & Insônia', href: '/blog/categoria/sono' },
  { label: 'Ansiedade', href: '/blog/categoria/ansiedade' },
  { label: 'Ingredientes', href: '/blog/categoria/ingredientes' },
  { label: 'Hábitos', href: '/blog/categoria/habitos' },
]

const toolLinks = [
  { label: 'Calculadora de Sono', href: '/blog/calculadora-de-sono/', icon: '🌙' },
  { label: 'Quiz do Sono',        href: '/blog/quiz-do-sono/',        icon: '😴' },
  { label: 'Quiz Dopaminérgico',  href: '/blog/quiz-dopamina/',       icon: '⚡' },
  { label: 'Teste de Ansiedade',  href: '/blog/teste-de-ansiedade/',  icon: '🧠' },
]
---
<header style="background: #0D1B3E; border-bottom: 1px solid rgba(29,184,232,0.15); position: sticky; top: 0; z-index: 40; box-shadow: 0 2px 20px rgba(0,0,0,0.3);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between" style="height: 64px;">

      <!-- Logo -->
      <a href="/blog" style="text-decoration: none; display: flex; align-items: baseline; gap: 4px; line-height: 1;">
        <span style="font-family: 'Sora', system-ui, sans-serif; font-weight: 900; font-size: 1.4rem; color: #1DB8E8; letter-spacing: -0.02em;">ZEN</span>
        <span style="font-family: 'DM Sans', system-ui, sans-serif; font-style: italic; font-weight: 600; color: #ffffff; font-size: 1rem;">caps</span>
        <span style="color: #6B7A9A; font-size: 0.65rem; margin-left: 8px; letter-spacing: 0.12em; text-transform: uppercase; font-family: 'DM Sans', system-ui, sans-serif; align-self: center;">Blog</span>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            style="font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.75); text-decoration: none; transition: color 0.15s; font-family: 'DM Sans', system-ui, sans-serif;"
            onmouseover="this.style.color='#1DB8E8'"
            onmouseout="this.style.color='rgba(255,255,255,0.75)'"
          >
            {link.label}
          </a>
        ))}

        <!-- Ferramentas dropdown -->
        <div id="tools-dropdown" style="position: relative;">
          <button
            id="tools-btn"
            style="font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.75); background: none; border: none; cursor: pointer; font-family: 'DM Sans', system-ui, sans-serif; display: flex; align-items: center; gap: 4px; transition: color 0.15s; padding: 0;"
            onmouseover="this.style.color='#1DB8E8'"
            onmouseout="this.style.color='rgba(255,255,255,0.75)'"
          >
            Ferramentas
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/></svg>
          </button>
          <div
            id="tools-panel"
            style="display: none; position: absolute; top: calc(100% + 12px); right: -20px; background: #0D1B3E; border: 1px solid rgba(29,184,232,0.2); border-radius: 14px; padding: 8px; min-width: 220px; box-shadow: 0 12px 40px rgba(0,0,0,0.4); z-index: 50;"
          >
            {toolLinks.map(tool => (
              <a
                href={tool.href}
                style="display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 10px; text-decoration: none; font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.8); font-family: 'DM Sans', system-ui, sans-serif; transition: background 0.15s;"
                onmouseover="this.style.background='rgba(29,184,232,0.1)'"
                onmouseout="this.style.background='transparent'"
              >
                <span style="font-size: 1rem;">{tool.icon}</span>
                {tool.label}
              </a>
            ))}
          </div>
        </div>
      </nav>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">

        <!-- Search icon -->
        <a
          href="/blog/busca"
          aria-label="Buscar artigos"
          style="
            display: flex; align-items: center; justify-content: center;
            width: 36px; height: 36px; border-radius: 10px;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            transition: color 0.15s, background 0.15s;
          "
          onmouseover="this.style.color='#1DB8E8'; this.style.background='rgba(29,184,232,0.1)'"
          onmouseout="this.style.color='rgba(255,255,255,0.65)'; this.style.background='transparent'"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>

        <a
          href="https://zencaps.com.br"
          target="_blank"
          rel="noopener noreferrer"
          id="header-cta"
          class="zen-btn-gold"
          style="display: none; padding: 0.45rem 1.25rem; font-size: 0.82rem;"
        >
          Comprar Zen Caps
        </a>

        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          style="padding: 8px; border-radius: 8px; background: transparent; border: none; cursor: pointer; color: rgba(255,255,255,0.7);"
          class="md:hidden"
          aria-label="Abrir menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4" style="border-top: 1px solid rgba(29,184,232,0.15); padding-top: 12px;">
      {navLinks.map(link => (
        <a
          href={link.href}
          style="display: block; padding: 10px 0; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.8); text-decoration: none; font-family: 'DM Sans', system-ui, sans-serif; transition: color 0.15s;"
          onmouseover="this.style.color='#1DB8E8'"
          onmouseout="this.style.color='rgba(255,255,255,0.8)'"
        >
          {link.label}
        </a>
      ))}
      <!-- Ferramentas mobile -->
      <div style="border-top: 1px solid rgba(29,184,232,0.1); margin-top: 4px; padding-top: 8px;">
        <p style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #1DB8E8; margin: 0 0 6px; font-family: 'DM Sans', system-ui, sans-serif;">Ferramentas Gratuitas</p>
        {toolLinks.map(tool => (
          <a
            href={tool.href}
            style="display: flex; align-items: center; gap: 8px; padding: 8px 0; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.8); text-decoration: none; font-family: 'DM Sans', system-ui, sans-serif; transition: color 0.15s;"
            onmouseover="this.style.color='#1DB8E8'"
            onmouseout="this.style.color='rgba(255,255,255,0.8)'"
          >
            <span style="font-size: 0.95rem;">{tool.icon}</span>
            {tool.label}
          </a>
        ))}
      </div>

      <a
        href="/blog/busca"
        style="display: flex; align-items: center; gap: 8px; padding: 10px 0; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.8); text-decoration: none; font-family: 'DM Sans', system-ui, sans-serif; transition: color 0.15s; border-top: 1px solid rgba(29,184,232,0.1); margin-top: 4px;"
        onmouseover="this.style.color='#1DB8E8'"
        onmouseout="this.style.color='rgba(255,255,255,0.8)'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        Buscar artigos
      </a>
      <a
        href="/blog/sobre"
        style="display: flex; align-items: center; gap: 8px; padding: 10px 0; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.8); text-decoration: none; font-family: 'DM Sans', system-ui, sans-serif; transition: color 0.15s; border-top: 1px solid rgba(29,184,232,0.1);"
        onmouseover="this.style.color='#1DB8E8'"
        onmouseout="this.style.color='rgba(255,255,255,0.8)'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
        Sobre a equipe
      </a>
      <a
        href="/blog/contato"
        style="display: flex; align-items: center; gap: 8px; padding: 10px 0; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.8); text-decoration: none; font-family: 'DM Sans', system-ui, sans-serif; transition: color 0.15s; border-top: 1px solid rgba(29,184,232,0.1);"
        onmouseover="this.style.color='#1DB8E8'"
        onmouseout="this.style.color='rgba(255,255,255,0.8)'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Contato
      </a>
      <a
        href="https://zencaps.com.br"
        target="_blank"
        rel="noopener noreferrer"
        class="zen-btn-gold"
        style="margin-top: 12px; display: block; text-align: center; padding: 0.6rem 1.5rem;"
      >
        Comprar Zen Caps
      </a>
    </div>
  </div>
</header>

<style is:inline>
  @media (min-width: 768px) {
    #header-cta { display: inline-flex !important; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'))

  // Tools dropdown (desktop)
  const toolsBtn = document.getElementById('tools-btn')
  const toolsPanel = document.getElementById('tools-panel')
  const toolsDropdown = document.getElementById('tools-dropdown')

  toolsBtn?.addEventListener('click', (e) => {
    e.stopPropagation()
    const isOpen = toolsPanel?.style.display === 'block'
    toolsPanel!.style.display = isOpen ? 'none' : 'block'
  })

  document.addEventListener('click', (e) => {
    if (toolsDropdown && !toolsDropdown.contains(e.target as Node)) {
      toolsPanel!.style.display = 'none'
    }
  })
</script>
